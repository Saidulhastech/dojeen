              </a>
            </div>

            <!-- Search icon (mobile only) -->
            <a href="/search" class="mobile-search-btn" aria-label="Search">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </a>

            <!-- User icon (mobile only) -->
            <a href="/account" class="mobile-user-link" aria-label="Account">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 18 20" fill="none">
                <path d="M16.1114 18.8889V16.6338C16.1114 15.2535 15.49 13.8999 14.234 13.3273C12.702 12.629 10.8647 12.2222 8.88921 12.2222C6.91377 12.2222 5.07644 12.629 3.54441 13.3273C2.2884 13.8999 1.66699 15.2535 1.66699 16.6338V18.8889" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8.88889 8.88886C11.0367 8.88886 12.7778 7.14775 12.7778 4.99997C12.7778 2.8522 11.0367 1.11108 8.88889 1.11108C6.74111 1.11108 5 2.8522 5 4.99997C5 7.14775 6.74111 8.88886 8.88889 8.88886Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <!-- Wishlist -->
            <a href="/wishlist" class="wishlist-link" aria-label="Wishlist">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
              </svg>
              <span id="headerWishlistCount" class="wishlist-count" hidden>0</span>
            </a>

            <!-- Cart button -->
            <button id="cartOpenBtn" class="cart-button w-inline-block" aria-label="Open cart">
              <svg width="17px" height="17px" viewBox="0 0 17 17" fill="none">
                <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                  <path d="M2.60592789,2 L0,2 L0,0 L4.39407211,0 L4.84288393,4 L16,4 L16,9.93844589 L3.76940945,12.3694378 L2.60592789,2 Z M15.5,17 C14.6715729,17 14,16.3284271 14,15.5 C14,14.6715729 14.6715729,14 15.5,14 C16.3284271,14 17,14.6715729 17,15.5 C17,16.3284271 16.3284271,17 15.5,17 Z M5.5,17 C4.67157288,17 4,16.3284271 4,15.5 C4,14.6715729 4.67157288,14 5.5,14 C6.32842712,14 7,14.6715729 7,15.5 C7,16.3284271 6.32842712,17 5.5,17 Z" fill="currentColor" fill-rule="nonzero" />
                </g>
              </svg>
              <div class="cart-text-block">
                <div class="cart-button-text w-inline-block">Cart</div>
                <div id="headerCartCount" class="w-commerce-commercecartopenlinkcount cart-quantity">0</div>
              </div>
            </button>

            <!-- Mobile hamburger -->
            <button class="menu-button" id="mobileMenuBtn" aria-label="Toggle menu" aria-expanded="false">
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

</header>

<!-- Mobile nav overlay + panel sit OUTSIDE <header> so that the header's
     will-change:transform does not become their containing block, which would
     confine position:fixed children to the header's own height (~110px). -->
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>

<nav class="mobile-nav-panel" id="mobileNavPanel">
  <div class="mobile-nav-inner">

    <!-- Branded header -->
    <div class="mobile-nav-header">
      <a href="/" class="mobile-nav-logo-link">
        <img src="/images/brand-logo.png" alt="Dojeen" class="mobile-nav-logo-img" />
      </a>
      <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Nav body -->
    <div class="mobile-nav-body">

      <!-- Search -->
      <form action="/search" class="mobile-nav-search" role="search">
        <svg class="mobile-nav-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          class="mobile-nav-search-input"
          type="search"
          name="query"
          placeholder="Search products..."
          aria-label="Search products"
          maxlength="256"
          autocomplete="off"
        />
      </form>

      <a href="/" class="mobile-nav-link">Home</a>
      <div class="mobile-nav-group">
        <button class="mobile-nav-group-toggle" data-mobile-group>
          Shop
          <span class="mobile-nav-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </button>
        <div class="mobile-nav-group-items">
          <a href="/shop" class="mobile-nav-sub-link">Shop with Sidebar</a>
          <a href="/shop/no-sidebar" class="mobile-nav-sub-link">Shop without Sidebar</a>
        </div>
      </div>
      <div class="mobile-nav-group">
        <button class="mobile-nav-group-toggle" data-mobile-group>
          Pages
          <span class="mobile-nav-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </button>
        <div class="mobile-nav-group-items">
          <a href="/about" class="mobile-nav-sub-link">About Us</a>
          <a href="/blog" class="mobile-nav-sub-link">Blog</a>
          <a href="/auth/login" class="mobile-nav-sub-link">Login &amp; Register</a>
          <a href="/auth/forgot-password" class="mobile-nav-sub-link">Forgot Password</a>
          <a href="/template-info/style-guide" class="mobile-nav-sub-link">Style Guide</a>
          <a href="/template-info/licenses" class="mobile-nav-sub-link">Licenses</a>
          <a href="/template-info/changelog" class="mobile-nav-sub-link">Changelog</a>
          <a href="/404" class="mobile-nav-sub-link">404 Page</a>
        </div>
      </div>
      <a href="/contact" class="mobile-nav-link">Contact</a>

    </div>

    <!-- Footer CTA -->
    <div class="mobile-nav-footer">
      <a href="/shop/no-sidebar" class="mobile-nav-cta">Shop Collection</a>
    </div>

  </div>
</nav>

<style>
  /* User icon: hidden on desktop (shown in desktop nav), visible on mobile */
  .mobile-user-link {
    display: none;
    align-items: center;
    justify-content: center;
    color: var(--_color---black, #1d1d1d);
    text-decoration: none;
  }
  @media (max-width: 991px) {
    .mobile-user-link { display: flex; }
  }

  /* Hamburger button: hidden on desktop, circular black pill on mobile */
  .menu-button {
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: inherit;
  }
  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }
  @media (max-width: 991px) {
    .menu-button {
      display: flex;
      background-color: var(--_color---black, #1d1d1d);
      border: 1px solid var(--_color---black, #1d1d1d);
      border-radius: 50%;
      padding: 12px;
      color: #fff;
    }
    .nav-menu-wrapper { display: none; }
  }
  @media (max-width: 479px) {
    .menu-button { padding: 7px; }
  }

  /* Scroll hide/show */
  #site-header {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  /* Nav dropdown shape: hidden by default, slides in on link hover */
  .nav-dropdown-shape {
    width: 0;
    overflow: hidden;
    transition: width 0.3s ease;
    flex-shrink: 0;
  }
  .nav-dropdown-link-block:hover .nav-dropdown-shape {
    width: 16px;
  }

  /* Desktop dropdown */
  .w-dropdown { position: relative; }
  .w-dropdown-list {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 50;
    min-width: 200px;
    background: transparent;
    overflow: hidden;
  }
  .mega-menu { min-width: 400px; }
  .w-dropdown:hover .w-dropdown-list,
  .w-dropdown.open .w-dropdown-list { display: block; }
</style>

<script is:inline>
  (function () {
    // Desktop dropdowns
    document.querySelectorAll('[data-dropdown]').forEach(function (dd) {
      var toggle = dd.querySelector('[data-dropdown-toggle]');
      if (toggle) {
        toggle.addEventListener('click', function (e) {
          e.stopPropagation();
          var isOpen = dd.classList.contains('open');
          document.querySelectorAll('[data-dropdown].open').forEach(function (o) { o.classList.remove('open'); });
          if (!isOpen) dd.classList.add('open');
        });
      }
    });
    document.addEventListener('click', function () {
      document.querySelectorAll('[data-dropdown].open').forEach(function (o) { o.classList.remove('open'); });
    });

    // Mobile menu
    var btn = document.getElementById('mobileMenuBtn');
    var panel = document.getElementById('mobileNavPanel');
    var overlay = document.getElementById('mobileNavOverlay');
    function openMenu() {
      panel && panel.classList.add('open');
      overlay && overlay.classList.add('open');
      btn && btn.setAttribute('aria-expanded', 'true');
    }
    function closeMenu() {
      panel && panel.classList.remove('open');
      overlay && overlay.classList.remove('open');
      btn && btn.setAttribute('aria-expanded', 'false');
    }
    btn && btn.addEventListener('click', function () {
      panel && panel.classList.contains('open') ? closeMenu() : openMenu();
    });
    var closeBtn = document.getElementById('mobileNavClose');
    closeBtn && closeBtn.addEventListener('click', closeMenu);
    overlay && overlay.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });

    // Mobile group toggles — also toggle .open on the parent group for arrow rotation
    document.querySelectorAll('[data-mobile-group]').forEach(function (toggle) {
      toggle.addEventListener('click', function () {
        var items = toggle.nextElementSibling;
        var group = toggle.parentElement;
        if (items) items.classList.toggle('open');
        if (group) group.classList.toggle('open');
      });
    });

    // Scroll hide/show: hide on scroll-down, show nav-only on scroll-up, full at top
    // Matches Webflow GSAP: y="-100%" down, y="-40px" up (hides 40px top-bar), y=0 at top
    // Also adds .is-scrolled for the glass backdrop effect on the main nav.
    (function () {
      var header = document.getElementById('site-header');
      if (!header) return;
      var lastY = window.pageYOffset;
      window.addEventListener('scroll', function () {
        var y = window.pageYOffset;
        if (y <= 0) {
          header.style.transform = '';
          header.classList.remove('is-scrolled');
        } else if (y > lastY + 2) {
          header.style.transform = 'translateY(-100%)';
          header.classList.add('is-scrolled');
        } else if (y < lastY - 2) {
          header.style.transform = 'translateY(-40px)';
          header.classList.add('is-scrolled');
        }
        lastY = y;
      }, { passive: true });
    })();

    // Cart open button
    var cartBtn = document.getElementById('cartOpenBtn');
    if (cartBtn) {
      cartBtn.addEventListener('click', function () {
        if (typeof window.__dojeenOpenCart === 'function') window.__dojeenOpenCart();
      });
    }

    // Update cart count badge from the server cart broadcast by @/lib/cart.
    function updateCartCount(e) {
      var cart = e && e.detail ? e.detail.cart : null;
      var count = cart && cart.totalQuantity ? cart.totalQuantity : 0;
      var badge = document.getElementById('headerCartCount');
      if (badge) badge.textContent = count;
    }
    window.addEventListener('cart:updated', updateCartCount);
  })();
</script>

<!-- Predictive (instant) search dropdown — injected HTML, so styles are global. -->
<style is:global>
  .search-predict-wrap { position: relative; }
  .search-predict {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: min(360px, 90vw);
    max-height: 70vh;
    overflow-y: auto;
    background: #fff;
    border: 1px solid #f0f0f0;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    z-index: 9997;
    padding: 6px;
  }
  .search-predict[hidden] { display: none; }
  .search-predict-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 10px;
    border-radius: 6px;
    text-decoration: none;
    color: #1d1d1d;
    transition: background 0.15s;
  }
  .search-predict-item:hover,
  .search-predict-item.is-active { background: #f6f6f5; }
  .search-predict-thumb {
    width: 44px;
    height: 54px;
    object-fit: cover;
    flex-shrink: 0;
    background: #f5f5f4;
    border-radius: 4px;
  }
  .search-predict-info { min-width: 0; flex: 1; }
  .search-predict-name {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .search-predict-price { font-size: 13px; color: #6b6b6b; }
  .search-predict-msg {
    padding: 14px 12px;
    font-size: 13px;
    color: #9b9b9b;
    text-align: center;
  }
  .search-predict-all {
    display: block;
    text-align: center;
    padding: 10px;
    margin-top: 4px;
    border-top: 1px solid #f0f0f0;
    font-size: 13px;
    font-weight: 600;
    color: #1d1d1d;
    text-decoration: none;
  }
  .search-predict-all:hover { color: #d0473e; }
</style>

<script is:inline>
  (function () {
    var input = document.getElementById('search');
    var panel = document.getElementById('searchPredict');
    if (!input || !panel) return;

    var timer;
    var lastQuery = '';

    function money(amount, code) {
      var n = Number(amount);
      try {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: code || 'USD' }).format(n);
      } catch (e) {
        return n.toFixed(2) + ' ' + (code || '');
      }
    }
    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
      });
    }
    function hide() { panel.hidden = true; panel.innerHTML = ''; }

    function render(query, products) {
      if (!products.length) {
        panel.innerHTML = '<div class="search-predict-msg">No matches for “' + esc(query) + '”</div>';
        panel.hidden = false;
        return;
      }
      var html = products.slice(0, 6).map(function (p) {
        var img = (p.featuredImage && p.featuredImage.url) || '';
        // Request a thumbnail-sized render from Shopify's CDN (displayed ~44px).
        if (img && img.indexOf('cdn.shopify.com') > -1) {
          img += (img.indexOf('?') > -1 ? '&' : '?') + 'width=120';
        }
        var price = p.priceRange && p.priceRange.minVariantPrice
          ? money(p.priceRange.minVariantPrice.amount, p.priceRange.minVariantPrice.currencyCode)
          : '';
        return (
          '<a class="search-predict-item" role="option" href="/products/' + encodeURIComponent(p.handle) + '">' +
            '<img class="search-predict-thumb" src="' + esc(img) + '" alt="' + esc(p.title) + '" loading="lazy" />' +
            '<div class="search-predict-info">' +
              '<div class="search-predict-name">' + esc(p.title) + '</div>' +
              '<div class="search-predict-price">' + price + '</div>' +
            '</div>' +
          '</a>'
        );
      }).join('');
      html += '<a class="search-predict-all" href="/search?query=' + encodeURIComponent(query) + '">View all results →</a>';
      panel.innerHTML = html;
      panel.hidden = false;
    }

    function run(query) {
      fetch('/api/search?q=' + encodeURIComponent(query), { headers: { accept: 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (input.value.trim() !== query) return; // stale response
          render(query, (data && data.products) || []);
        })
        .catch(function () { hide(); });
    }

    input.addEventListener('input', function () {
      var q = input.value.trim();
      window.clearTimeout(timer);
      if (q.length < 2) { hide(); return; }
      if (q === lastQuery && !panel.hidden) return;
      lastQuery = q;
      timer = window.setTimeout(function () { run(q); }, 200);
    });

    input.addEventListener('focus', function () {
      if (input.value.trim().length >= 2 && panel.innerHTML) panel.hidden = false;
    });

    document.addEventListener('click', function (e) {
      if (!panel.hidden && !panel.contains(e.target) && e.target !== input) hide();
    });
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') hide();
    });
  })();
</script>

---
interface Props {
  variant?: 'default' | 'homepage' | 'transparent';
  currentPath?: string;
}

const { variant = 'default', currentPath = '/' } = Astro.props;

const headerClass = variant === 'homepage' || variant === 'transparent'
  ? 'header header-homepage'
  : 'header';
---

<header id="site-header" class={headerClass}>
  <!-- Top bar -->
  <div class="header-top-bar">
    <div class="header-top-bar-wrapper">
      <div class="w-layout-blockcontainer container-fluid w-container">
        <div class="header-top-bar-inner">
          <div class="header-top-banner-text">
            Use Coupon Code 20% Off for Offers.{' '}
            <a href="/shop" class="header-top-bar-text-link">Shop Now</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="header-main">
    <div class="w-layout-blockcontainer container-fluid w-container">
      <div class="navbar-container">
        <div class="navbar-wrapper">
          <!-- Logo -->
          <div class="header-middle">
            <a href="/" class={`header-logo-link w-inline-block${currentPath === '/' ? ' w--current' : ''}`}>
              <img alt="Brand Logo" src="/images/brand-logo.png" class="header-logo" />
            </a>
          </div>

          <!-- Desktop Nav -->
          <nav role="navigation" class="nav-menu-wrapper" id="nav-menu">
            <div class="nav-menu-inner">
              <ul role="list" class="header-nav-menu-list">
                <li class="header-nav-list-item">
                  <a href="/" class={`header-nav-link w-inline-block${currentPath === '/' ? ' w--current' : ''}`}>
                    <div class="header-nav-link-text">Home</div>
                    <div class="header-nav-link-line"></div>
                  </a>
                </li>
                <li class="header-nav-list-item">
                  <div class="header-nav-dropdown w-dropdown" data-dropdown>
                    <div class="header-nav-dropdown-toggle w-dropdown-toggle">
                      <a href="/shop" class="header-dropdown-text-block">
                        <div class="header-dropdown-text">Shop</div>
                        <div class="header-nav-link-line"></div>
                      </a>
                      <div class="link-icon w-embed" data-dropdown-toggle>
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none">
                          <path d="M4.79835 5.99319C4.62636 5.99319 4.45438 5.92128 4.32326 5.77777L0.196869 1.25949C-0.065623 0.972075 -0.065623 0.506075 0.196869 0.218773C0.459255 -0.0685297 0.884756 -0.0685297 1.14727 0.218773L4.79835 4.2168L8.44945 0.218912C8.71194 -0.06839 9.1374 -0.06839 9.39977 0.218912C9.66238 0.506215 9.66238 0.972214 9.39977 1.25963L5.27344 5.77791C5.14225 5.92145 4.97028 5.99319 4.79835 5.99319Z" fill="currentColor" />
                        </svg>
                      </div>
                    </div>
                    <nav class="header-nav-dropdown-body w-dropdown-list">
                      <div class="header-nav-dropdown-inner">
                        <a href="/shop" class="nav-dropdown-link-block w-inline-block">
                          <div class="nav-dropdown-shape"></div>
                          <div class="nav-dropdown-link-text">Shop with sidebar</div>
                        </a>
                        <a href="/shop/no-sidebar" class="nav-dropdown-link-block w-inline-block">
                          <div class="nav-dropdown-shape"></div>
                          <div class="nav-dropdown-link-text">Shop without sidebar</div>
                        </a>
                      </div>
                    </nav>
                  </div>
                </li>
                <li class="header-nav-list-item">
                  <div class="header-nav-dropdown w-dropdown" data-dropdown>
                    <div class="header-nav-dropdown-toggle w-dropdown-toggle" data-dropdown-toggle>
                      <div class="header-dropdown-text-block">
                        <div class="header-dropdown-text">Pages</div>
                        <div class="header-nav-link-line"></div>
                      </div>
                      <div class="link-icon w-embed">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none">
                          <path d="M4.79835 5.99319C4.62636 5.99319 4.45438 5.92128 4.32326 5.77777L0.196869 1.25949C-0.065623 0.972075 -0.065623 0.506075 0.196869 0.218773C0.459255 -0.0685297 0.884756 -0.0685297 1.14727 0.218773L4.79835 4.2168L8.44945 0.218912C8.71194 -0.06839 9.1374 -0.06839 9.39977 0.218912C9.66238 0.506215 9.66238 0.972214 9.39977 1.25963L5.27344 5.77791C5.14225 5.92145 4.97028 5.99319 4.79835 5.99319Z" fill="currentColor" />
                        </svg>
                      </div>
                    </div>
                    <nav class="header-nav-dropdown-body mega-menu w-dropdown-list">
                      <div class="header-nav-dropdown-inner">
                        <div class="nav-dropdown-flex">
                          <div class="nav-dropdown-coloumn">
                            <div class="nav-dropdown-title">Pages</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/about" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">About Us</div>
                              </a>
                              <a href="/blog" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Blog</div>
                              </a>
                              <a href="/auth/login" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Login &amp; Register</div>
                              </a>
                              <a href="/auth/forgot-password" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Forgot Password</div>
                              </a>
                            </div>
                            <div class="nav-dropdown-title">CMS Pages</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/products/fitted-classic-blue-denim-jacket" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Product Details</div>
                              </a>
                              <a href="/blog/easy-outfit-formulas-that-simplify-daily-dressing" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Blog Details</div>
                              </a>
                            </div>
                          </div>
                          <div class="nav-dropdown-coloumn">
                            <div class="nav-dropdown-title">Template Info</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/template-info/style-guide" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Style Guide</div>
                              </a>
                              <a href="/template-info/licenses" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Licenses</div>
                              </a>
                              <a href="/template-info/changelog" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Changelog</div>
                              </a>
                              <a href="/template-info/instruction" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Instruction</div>
                              </a>
                            </div>
                            <div class="nav-dropdown-title">Utility Pages</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/404" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">404 Page</div>
                              </a>
                            </div>
                          </div>
                        </div>
                      </div>
                    </nav>
                  </div>
                </li>
                <li class="header-nav-list-item">
                  <a href="/contact" class={`header-nav-link w-inline-block${currentPath === '/contact' ? ' w--current' : ''}`}>
                    <div class="header-nav-link-text">Contact</div>
                    <div class="header-nav-link-line"></div>
                  </a>
                </li>
              </ul>

            </div>
          </nav>

          <!-- Cart + Hamburger -->
          <div class="nav-button-block">
            <!-- Search + User (desktop) -->
            <div class="header-right-side">
              <div class="search-predict-wrap">
                <form action="/search" class="search w-form" role="search">
                  <label for="search" class="visually-hidden">Search products</label>
                  <input
                    class="search-input w-input"
                    maxlength="256"
                    name="query"
                    placeholder="Search products....."
                    type="search"
                    id="search"
                    autocomplete="off"
                  />
                  <input type="submit" class="search-button w-button" value="" aria-label="Search" />
                </form>
                <div class="search-predict" id="searchPredict" role="listbox" aria-label="Search suggestions" hidden></div>
              </div>
              <a href="/account" class="user-link-blcok w-inline-block" aria-label="Account">
                <div class="user-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="20" viewBox="0 0 18 20" fill="none">
                    <path d="M16.1114 18.8889V16.6338C16.1114 15.2535 15.49 13.8999 14.234 13.3273C12.702 12.629 10.8647 12.2222 8.88921 12.2222C6.91377 12.2222 5.07644 12.629 3.54441 13.3273C2.2884 13.8999 1.66699 15.2535 1.66699 16.6338V18.8889" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M8.88889 8.88886C11.0367 8.88886 12.7778 7.14775 12.7778 4.99997C12.7778 2.8522 11.0367 1.11108 8.88889 1.11108C6.74111 1.11108 5 2.8522 5 4.99997C5 7.14775 6.74111 8.88886 8.88889 8.88886Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>

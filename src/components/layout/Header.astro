---
interface Props {
  variant?: 'default' | 'homepage' | 'transparent';
  currentPath?: string;
}

const { variant = 'default', currentPath = '/' } = Astro.props;

const headerClass = variant === 'homepage' || variant === 'transparent'
  ? 'header header-homepage'
  : 'header';
---

<header id="site-header" class={headerClass}>
  <!-- Top bar -->
  <div class="header-top-bar">
    <div class="header-top-bar-wrapper">
      <div class="w-layout-blockcontainer container-fluid w-container">
        <div class="header-top-bar-inner">
          <div class="header-top-banner-text">
            Use Coupon Code 20% Off for Offers.{' '}
            <a href="/shop" class="header-top-bar-text-link">Shop Now</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="header-main">
    <div class="w-layout-blockcontainer container-fluid w-container">
      <div class="navbar-container">
        <div class="navbar-wrapper">
          <!-- Logo -->
          <div class="header-middle">
            <a href="/" class={`header-logo-link w-inline-block${currentPath === '/' ? ' w--current' : ''}`}>
              <img alt="Brand Logo" src="/images/brand-logo.png" class="header-logo" />
            </a>
          </div>

          <!-- Desktop Nav -->
          <nav role="navigation" class="nav-menu-wrapper" id="nav-menu">
            <div class="nav-menu-inner">
              <ul role="list" class="header-nav-menu-list">
                <li class="header-nav-list-item">
                  <a href="/" class={`header-nav-link w-inline-block${currentPath === '/' ? ' w--current' : ''}`}>
                    <div class="header-nav-link-text">Home</div>
                    <div class="header-nav-link-line"></div>
                  </a>
                </li>
                <li class="header-nav-list-item">
                  <div class="header-nav-dropdown w-dropdown" data-dropdown>
                    <div class="header-nav-dropdown-toggle w-dropdown-toggle">
                      <a href="/shop" class="header-dropdown-text-block">
                        <div class="header-dropdown-text">Shop</div>
                        <div class="header-nav-link-line"></div>
                      </a>
                      <div class="link-icon w-embed" data-dropdown-toggle>
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none">
                          <path d="M4.79835 5.99319C4.62636 5.99319 4.45438 5.92128 4.32326 5.77777L0.196869 1.25949C-0.065623 0.972075 -0.065623 0.506075 0.196869 0.218773C0.459255 -0.0685297 0.884756 -0.0685297 1.14727 0.218773L4.79835 4.2168L8.44945 0.218912C8.71194 -0.06839 9.1374 -0.06839 9.39977 0.218912C9.66238 0.506215 9.66238 0.972214 9.39977 1.25963L5.27344 5.77791C5.14225 5.92145 4.97028 5.99319 4.79835 5.99319Z" fill="currentColor" />
                        </svg>
                      </div>
                    </div>
                    <nav class="header-nav-dropdown-body w-dropdown-list">
                      <div class="header-nav-dropdown-inner">
                        <a href="/shop" class="nav-dropdown-link-block w-inline-block">
                          <div class="nav-dropdown-shape"></div>
                          <div class="nav-dropdown-link-text">Shop with sidebar</div>
                        </a>
                        <a href="/shop/no-sidebar" class="nav-dropdown-link-block w-inline-block">
                          <div class="nav-dropdown-shape"></div>
                          <div class="nav-dropdown-link-text">Shop without sidebar</div>
                        </a>
                      </div>
                    </nav>
                  </div>
                </li>
                <li class="header-nav-list-item">
                  <div class="header-nav-dropdown w-dropdown" data-dropdown>
                    <div class="header-nav-dropdown-toggle w-dropdown-toggle" data-dropdown-toggle>
                      <div class="header-dropdown-text-block">
                        <div class="header-dropdown-text">Pages</div>
                        <div class="header-nav-link-line"></div>
                      </div>
                      <div class="link-icon w-embed">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none">
                          <path d="M4.79835 5.99319C4.62636 5.99319 4.45438 5.92128 4.32326 5.77777L0.196869 1.25949C-0.065623 0.972075 -0.065623 0.506075 0.196869 0.218773C0.459255 -0.0685297 0.884756 -0.0685297 1.14727 0.218773L4.79835 4.2168L8.44945 0.218912C8.71194 -0.06839 9.1374 -0.06839 9.39977 0.218912C9.66238 0.506215 9.66238 0.972214 9.39977 1.25963L5.27344 5.77791C5.14225 5.92145 4.97028 5.99319 4.79835 5.99319Z" fill="currentColor" />
                        </svg>
                      </div>
                    </div>
                    <nav class="header-nav-dropdown-body mega-menu w-dropdown-list">
                      <div class="header-nav-dropdown-inner">
                        <div class="nav-dropdown-flex">
                          <div class="nav-dropdown-coloumn">
                            <div class="nav-dropdown-title">Pages</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/about" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">About Us</div>
                              </a>
                              <a href="/blog" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Blog</div>
                              </a>
                              <a href="/auth/login" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Login &amp; Register</div>
                              </a>
                              <a href="/auth/forgot-password" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Forgot Password</div>
                              </a>
                            </div>
                            <div class="nav-dropdown-title">CMS Pages</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/products/fitted-classic-blue-denim-jacket" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Product Details</div>
                              </a>
                              <a href="/blog/easy-outfit-formulas-that-simplify-daily-dressing" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Blog Details</div>
                              </a>
                            </div>
                          </div>
                          <div class="nav-dropdown-coloumn">
                            <div class="nav-dropdown-title">Template Info</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/template-info/style-guide" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Style Guide</div>
                              </a>
                              <a href="/template-info/licenses" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Licenses</div>
                              </a>
                              <a href="/template-info/changelog" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Changelog</div>
                              </a>
                              <a href="/template-info/instruction" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">Instruction</div>
                              </a>
                            </div>
                            <div class="nav-dropdown-title">Utility Pages</div>
                            <div class="nav-dropdown-link-wrapper">
                              <a href="/404" class="nav-dropdown-link-block w-inline-block">
                                <div class="nav-dropdown-shape"></div>
                                <div class="nav-dropdown-link-text">404 Page</div>
                              </a>
                            </div>
                          </div>
                        </div>
                      </div>
                    </nav>
                  </div>
                </li>
                <li class="header-nav-list-item">
                  <a href="/contact" class={`header-nav-link w-inline-block${currentPath === '/contact' ? ' w--current' : ''}`}>
                    <div class="header-nav-link-text">Contact</div>
                    <div class="header-nav-link-line"></div>
                  </a>
                </li>
              </ul>

            </div>
          </nav>

          <!-- Cart + Hamburger -->
          <div class="nav-button-block">
            <!-- Search + User (desktop) -->
            <div class="header-right-side">
              <form action="/search" class="search w-form">
                <input
                  class="search-input w-input"
                  maxlength="256"
                  name="query"
                  placeholder="Search products....."
                  type="search"
                  id="search"
                />
                <input type="submit" class="search-button w-button" value="" />
              </form>
              <a href="/auth/login" class="user-link-blcok w-inline-block">
                <div class="user-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="20" viewBox="0 0 18 20" fill="none">
                    <path d="M16.1114 18.8889V16.6338C16.1114 15.2535 15.49 13.8999 14.234 13.3273C12.702 12.629 10.8647 12.2222 8.88921 12.2222C6.91377 12.2222 5.07644 12.629 3.54441 13.3273C2.2884 13.8999 1.66699 15.2535 1.66699 16.6338V18.8889" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M8.88889 8.88886C11.0367 8.88886 12.7778 7.14775 12.7778 4.99997C12.7778 2.8522 11.0367 1.11108 8.88889 1.11108C6.74111 1.11108 5 2.8522 5 4.99997C5 7.14775 6.74111 8.88886 8.88889 8.88886Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
              </a>
            </div>

            <!-- Search icon (mobile only) -->
            <a href="/search" class="mobile-search-btn" aria-label="Search">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </a>

            <!-- User icon (mobile only) -->
            <a href="/auth/login" class="mobile-user-link" aria-label="Account">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 18 20" fill="none">
                <path d="M16.1114 18.8889V16.6338C16.1114 15.2535 15.49 13.8999 14.234 13.3273C12.702 12.629 10.8647 12.2222 8.88921 12.2222C6.91377 12.2222 5.07644 12.629 3.54441 13.3273C2.2884 13.8999 1.66699 15.2535 1.66699 16.6338V18.8889" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8.88889 8.88886C11.0367 8.88886 12.7778 7.14775 12.7778 4.99997C12.7778 2.8522 11.0367 1.11108 8.88889 1.11108C6.74111 1.11108 5 2.8522 5 4.99997C5 7.14775 6.74111 8.88886 8.88889 8.88886Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <!-- Cart button -->
            <button id="cartOpenBtn" class="cart-button w-inline-block" aria-label="Open cart">
              <svg width="17px" height="17px" viewBox="0 0 17 17" fill="none">
                <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                  <path d="M2.60592789,2 L0,2 L0,0 L4.39407211,0 L4.84288393,4 L16,4 L16,9.93844589 L3.76940945,12.3694378 L2.60592789,2 Z M15.5,17 C14.6715729,17 14,16.3284271 14,15.5 C14,14.6715729 14.6715729,14 15.5,14 C16.3284271,14 17,14.6715729 17,15.5 C17,16.3284271 16.3284271,17 15.5,17 Z M5.5,17 C4.67157288,17 4,16.3284271 4,15.5 C4,14.6715729 4.67157288,14 5.5,14 C6.32842712,14 7,14.6715729 7,15.5 C7,16.3284271 6.32842712,17 5.5,17 Z" fill="currentColor" fill-rule="nonzero" />
                </g>
              </svg>
              <div class="cart-text-block">
                <div class="cart-button-text w-inline-block">Cart</div>
                <div id="headerCartCount" class="w-commerce-commercecartopenlinkcount cart-quantity">0</div>
              </div>
            </button>

            <!-- Mobile hamburger -->
            <button class="menu-button" id="mobileMenuBtn" aria-label="Toggle menu" aria-expanded="false">
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

</header>

<!-- Mobile nav overlay + panel sit OUTSIDE <header> so that the header's
     will-change:transform does not become their containing block, which would
     confine position:fixed children to the header's own height (~110px). -->
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>

<nav class="mobile-nav-panel" id="mobileNavPanel">
  <div class="mobile-nav-inner">

    <!-- Branded header -->
    <div class="mobile-nav-header">
      <a href="/" class="mobile-nav-logo-link">
        <img src="/images/brand-logo.png" alt="Dojeen" class="mobile-nav-logo-img" />
      </a>
      <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Nav body -->
    <div class="mobile-nav-body">

      <!-- Search -->
      <form action="/search" class="mobile-nav-search" role="search">
        <svg class="mobile-nav-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          class="mobile-nav-search-input"
          type="search"
          name="query"
          placeholder="Search products..."
          maxlength="256"
          autocomplete="off"
        />
      </form>

      <a href="/" class="mobile-nav-link">Home</a>
      <div class="mobile-nav-group">
        <button class="mobile-nav-group-toggle" data-mobile-group>
          Shop
          <span class="mobile-nav-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </button>
        <div class="mobile-nav-group-items">
          <a href="/shop" class="mobile-nav-sub-link">Shop with Sidebar</a>
          <a href="/shop/no-sidebar" class="mobile-nav-sub-link">Shop without Sidebar</a>
        </div>
      </div>
      <div class="mobile-nav-group">
        <button class="mobile-nav-group-toggle" data-mobile-group>
          Pages
          <span class="mobile-nav-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </span>
        </button>
        <div class="mobile-nav-group-items">
          <a href="/about" class="mobile-nav-sub-link">About Us</a>
          <a href="/blog" class="mobile-nav-sub-link">Blog</a>
          <a href="/auth/login" class="mobile-nav-sub-link">Login &amp; Register</a>
          <a href="/auth/forgot-password" class="mobile-nav-sub-link">Forgot Password</a>
          <a href="/template-info/style-guide" class="mobile-nav-sub-link">Style Guide</a>
          <a href="/template-info/licenses" class="mobile-nav-sub-link">Licenses</a>
          <a href="/template-info/changelog" class="mobile-nav-sub-link">Changelog</a>
          <a href="/404" class="mobile-nav-sub-link">404 Page</a>
        </div>
      </div>
      <a href="/contact" class="mobile-nav-link">Contact</a>

    </div>

    <!-- Footer CTA -->
    <div class="mobile-nav-footer">
      <a href="/shop/no-sidebar" class="mobile-nav-cta">Shop Collection</a>
    </div>

  </div>
</nav>

<style>
  /* User icon: hidden on desktop (shown in desktop nav), visible on mobile */
  .mobile-user-link {
    display: none;
    align-items: center;
    justify-content: center;
    color: var(--_color---black, #1d1d1d);
    text-decoration: none;
  }
  @media (max-width: 991px) {
    .mobile-user-link { display: flex; }
  }

  /* Hamburger button: hidden on desktop, circular black pill on mobile */
  .menu-button {
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: inherit;
  }
  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }
  @media (max-width: 991px) {
    .menu-button {
      display: flex;
      background-color: var(--_color---black, #1d1d1d);
      border: 1px solid var(--_color---black, #1d1d1d);
      border-radius: 50%;
      padding: 12px;
      color: #fff;
    }
    .nav-menu-wrapper { display: none; }
  }
  @media (max-width: 479px) {
    .menu-button { padding: 7px; }
  }

  /* Scroll hide/show */
  #site-header {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  /* Nav dropdown shape: hidden by default, slides in on link hover */
  .nav-dropdown-shape {
    width: 0;
    overflow: hidden;
    transition: width 0.3s ease;
    flex-shrink: 0;
  }
  .nav-dropdown-link-block:hover .nav-dropdown-shape {
    width: 16px;
  }

  /* Desktop dropdown */
  .w-dropdown { position: relative; }
  .w-dropdown-list {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 50;
    min-width: 200px;
    background: transparent;
    overflow: hidden;
  }
  .mega-menu { min-width: 400px; }
  .w-dropdown:hover .w-dropdown-list,
  .w-dropdown.open .w-dropdown-list { display: block; }
</style>

<script is:inline>
  (function () {
    // Desktop dropdowns
    document.querySelectorAll('[data-dropdown]').forEach(function (dd) {
      var toggle = dd.querySelector('[data-dropdown-toggle]');
      if (toggle) {
        toggle.addEventListener('click', function (e) {
          e.stopPropagation();
          var isOpen = dd.classList.contains('open');
          document.querySelectorAll('[data-dropdown].open').forEach(function (o) { o.classList.remove('open'); });
          if (!isOpen) dd.classList.add('open');
        });
      }
    });
    document.addEventListener('click', function () {
      document.querySelectorAll('[data-dropdown].open').forEach(function (o) { o.classList.remove('open'); });
    });

    // Mobile menu
    var btn = document.getElementById('mobileMenuBtn');
    var panel = document.getElementById('mobileNavPanel');
    var overlay = document.getElementById('mobileNavOverlay');
    function openMenu() {
      panel && panel.classList.add('open');
      overlay && overlay.classList.add('open');
      btn && btn.setAttribute('aria-expanded', 'true');
    }
    function closeMenu() {
      panel && panel.classList.remove('open');
      overlay && overlay.classList.remove('open');
      btn && btn.setAttribute('aria-expanded', 'false');
    }
    btn && btn.addEventListener('click', function () {
      panel && panel.classList.contains('open') ? closeMenu() : openMenu();
    });
    var closeBtn = document.getElementById('mobileNavClose');
    closeBtn && closeBtn.addEventListener('click', closeMenu);
    overlay && overlay.addEventListener('click', closeMenu);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });

    // Mobile group toggles — also toggle .open on the parent group for arrow rotation
    document.querySelectorAll('[data-mobile-group]').forEach(function (toggle) {
      toggle.addEventListener('click', function () {
        var items = toggle.nextElementSibling;
        var group = toggle.parentElement;
        if (items) items.classList.toggle('open');
        if (group) group.classList.toggle('open');
      });
    });

    // Scroll hide/show: hide on scroll-down, show nav-only on scroll-up, full at top
    // Matches Webflow GSAP: y="-100%" down, y="-40px" up (hides 40px top-bar), y=0 at top
    // Also adds .is-scrolled for the glass backdrop effect on the main nav.
    (function () {
      var header = document.getElementById('site-header');
      if (!header) return;
      var lastY = window.pageYOffset;
      window.addEventListener('scroll', function () {
        var y = window.pageYOffset;
        if (y <= 0) {
          header.style.transform = '';
          header.classList.remove('is-scrolled');
        } else if (y > lastY + 2) {
          header.style.transform = 'translateY(-100%)';
          header.classList.add('is-scrolled');
        } else if (y < lastY - 2) {
          header.style.transform = 'translateY(-40px)';
          header.classList.add('is-scrolled');
        }
        lastY = y;
      }, { passive: true });
    })();

    // Cart open button
    var cartBtn = document.getElementById('cartOpenBtn');
    if (cartBtn) {
      cartBtn.addEventListener('click', function () {
        if (typeof window.__dojeenOpenCart === 'function') window.__dojeenOpenCart();
      });
    }

    // Update cart count badge
    function updateCartCount() {
      try {
        var items = JSON.parse(localStorage.getItem('dojeen_cart') || '[]');
        var count = items.reduce(function (s, i) { return s + (i.quantity || 0); }, 0);
        var badge = document.getElementById('headerCartCount');
        if (badge) badge.textContent = count;
      } catch (e) {}
    }
    updateCartCount();
    window.addEventListener('cart:updated', updateCartCount);
  })();
</script>

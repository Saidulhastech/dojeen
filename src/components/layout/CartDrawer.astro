---
---

<!-- Cart Drawer -->
<div id="cart-drawer-overlay" class="cart-drawer-overlay" aria-hidden="true"></div>

<div id="cart-drawer" class="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart">
  <div class="cart-drawer-header">
    <h4 class="cart-drawer-title">Your Cart</h4>
    <button id="cartCloseBtn" class="cart-drawer-close" aria-label="Close cart">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M15 1L1 15M1 1L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <!-- Free-shipping progress (hidden until there's a cart with items) -->
  <div id="cart-freeship" class="cart-freeship" style="display:none">
    <p class="cart-freeship-text" id="cart-freeship-text"></p>
    <div class="cart-freeship-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
      <span class="cart-freeship-fill" id="cart-freeship-fill"></span>
    </div>
  </div>

  <div class="cart-drawer-body">
    <div id="cart-items-list" class="cart-items-list"></div>
    <div id="cart-empty-state" class="cart-empty-state" style="display:none">
      <p>No items in your cart yet.</p>
      <a href="/shop" class="primary-button w-inline-block">
        <div class="button-text-block"><div class="button-text">Shop Now</div></div>
        <div class="button-bg"></div>
      </a>
    </div>
    <!-- Upsell rail (rendered by JS; hidden until there are recommendations) -->
    <div id="cart-upsell" class="cart-upsell" hidden></div>
  </div>

  <div id="cart-drawer-footer" class="cart-drawer-footer" style="display:none">
    <div class="cart-subtotal-row">
      <span>Subtotal</span>
      <span id="cart-subtotal">—</span>
    </div>
    <a href="#" id="cart-checkout-btn" class="cart-checkout-button">Continue to Checkout</a>
    <a href="/cart" class="cart-view-link">View Cart</a>
  </div>
</div>

<!-- is:global required — cart items are injected via JS innerHTML and don't receive Astro's scoped hash -->
<style is:global>
  .cart-drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 9998;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .cart-drawer-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(420px, 100vw);
    background: #fff;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s ease;
    box-shadow: -4px 0 30px rgba(0, 0, 0, 0.1);
  }
  .cart-drawer.open { transform: translateX(0); }

  .cart-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #f2f2f2;
    flex-shrink: 0;
  }
  .cart-drawer-title {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0;
    color: #1d1d1d;
  }
  .cart-drawer-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #333;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Free-shipping progress bar */
  .cart-freeship {
    flex-shrink: 0;
    padding: 14px 24px;
    border-bottom: 1px solid #f2f2f2;
    background: #faf9f7;
  }
  .cart-freeship-text {
    margin: 0 0 10px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.4;
    color: #1d1d1d;
  }
  .cart-freeship-text strong { font-weight: 600; }
  .cart-freeship.is-qualified .cart-freeship-text { color: #14854e; }
  .cart-freeship-track {
    position: relative;
    height: 6px;
    border-radius: 100px;
    background: #e7e4df;
    overflow: hidden;
  }
  .cart-freeship-fill {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0%;
    border-radius: 100px;
    background: #1d1d1d;
    transition: width 0.45s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s ease;
  }
  .cart-freeship.is-qualified .cart-freeship-fill { background: #14854e; }

  .cart-drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 24px;
  }

  /* Item list */
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .cart-item {
    display: flex;
    flex-direction: row;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid #f2f2f2;
    align-items: flex-start;
  }
  .cart-item-image {
    width: 72px;
    height: 90px;
    object-fit: cover;
    flex-shrink: 0;
    background: #f9f9f8;
    display: block;
  }
  .cart-item-info {
    flex: 1;
    min-width: 0;
  }
  .cart-item-name {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #1d1d1d;
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .cart-item-price {
    font-size: 14px;
    color: #1d1d1d;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .cart-item-meta {
    font-size: 12px;
    color: #9b9b9b;
    margin-bottom: 2px;
  }
  .cart-remove-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 12px;
    color: #9b9b9b;
    padding: 0;
    margin-top: 6px;
    text-decoration: underline;
    display: block;
    font-family: 'Inter', sans-serif;
  }
  .cart-remove-btn:hover { color: #1d1d1d; }

  /* Quantity controls (right column) */
  .cart-item-qty-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .cart-qty-btn {
    width: 26px;
    height: 26px;
    background: #f2f2f2;
    border: none;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    color: #1d1d1d;
    transition: background 0.15s;
  }
  .cart-qty-btn:hover { background: #e0e0e0; }
  .cart-qty-value {
    font-size: 14px;
    font-weight: 500;
    min-width: 20px;
    text-align: center;
    color: #1d1d1d;
  }

  /* Empty state */
  .cart-empty-state {
    text-align: center;
    padding: 40px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    color: #9b9b9b;
    font-size: 14px;
  }

  /* Footer */
  .cart-drawer-footer {
    padding: 16px 24px;
    border-top: 1px solid #f2f2f2;
    flex-shrink: 0;
  }
  .cart-subtotal-row {
    display: flex;
    justify-content: space-between;
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 14px;
    color: #1d1d1d;
  }
  .cart-checkout-button {
    display: block;
    width: 100%;
    padding: 15px;
    background: #1d1d1d;
    color: #fff;
    text-align: center;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Instrument Sans', sans-serif;
    letter-spacing: 0.02em;
    transition: background 0.2s;
    box-sizing: border-box;
  }
  .cart-checkout-button:hover { background: #3b3b3b; }
  .cart-view-link {
    display: block;
    text-align: center;
    margin-top: 10px;
    padding: 4px;
    color: #1d1d1d;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cart-view-link:hover { color: #d0473e; }

  /* ── Cart upsell rail (shared base for drawer + cart page) ── */
  .upsell-heading {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #1d1d1d;
    margin: 0 0 14px;
  }
  .upsell-list { display: flex; flex-direction: column; gap: 14px; }
  .upsell-card { display: flex; align-items: center; gap: 12px; }
  .upsell-thumb-link { flex-shrink: 0; display: block; }
  .upsell-thumb {
    width: 52px;
    height: 66px;
    object-fit: cover;
    display: block;
    background: #f4f2ef;
  }
  .upsell-body { flex: 1; min-width: 0; }
  .upsell-name {
    display: block;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #1d1d1d;
    text-decoration: none;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }
  .upsell-name:hover { color: #d0473e; }
  .upsell-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 3px;
    font-size: 13px;
    color: #1d1d1d;
  }
  .upsell-compare { font-size: 12px; color: #9b9b9b; text-decoration: line-through; }
  .upsell-add {
    flex-shrink: 0;
    border: 1px solid #1d1d1d;
    border-radius: 2px;
    background: #fff;
    color: #1d1d1d;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    padding: 8px 14px;
    min-height: 36px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .upsell-add:hover { background: #1d1d1d; color: #fff; }
  .upsell-add:disabled { opacity: 0.6; cursor: default; }

  /* Drawer placement: separated from the item list, scrolls with the body */
  .cart-upsell {
    margin-top: 8px;
    padding-top: 20px;
    border-top: 1px solid #f2f2f2;
  }
  .cart-upsell[hidden] { display: none; }
</style>

<!-- Open/close (no imports) — defines the global drawer opener. -->
<script is:inline>
  (function () {
    var drawer = document.getElementById('cart-drawer');
    var overlay = document.getElementById('cart-drawer-overlay');
    var closeBtn = document.getElementById('cartCloseBtn');
    function openDrawer() {
      drawer && drawer.classList.add('open');
      overlay && overlay.classList.add('open');
      overlay && overlay.removeAttribute('aria-hidden');
    }
    function closeDrawer() {
      drawer && drawer.classList.remove('open');
      overlay && overlay.classList.remove('open');
      overlay && overlay.setAttribute('aria-hidden', 'true');
    }
    window.__dojeenOpenCart = openDrawer;
    closeBtn && closeBtn.addEventListener('click', closeDrawer);
    overlay && overlay.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeDrawer(); });
  })();
</script>

<!-- Rendering — bundled so it can drive the server cart via @/lib/cart. -->
<script>
  import { initCart, getCurrentCart, updateLine, removeLine, type Cart, type CartLine } from '@/lib/cart';
  import { formatMoney } from '@/lib/money';
  import { freeShipProgress } from '@/lib/shipping';
  import { renderUpsell } from '@/lib/cart-upsell';
  import { sizedImg } from '@/lib/img';

  const itemsList = document.getElementById('cart-items-list');
  const upsellEl = document.getElementById('cart-upsell');
  const emptyState = document.getElementById('cart-empty-state');
  const footer = document.getElementById('cart-drawer-footer');
  const subtotalEl = document.getElementById('cart-subtotal');
  const checkoutBtn = document.getElementById('cart-checkout-btn') as HTMLAnchorElement | null;

  const freeship = document.getElementById('cart-freeship');
  const freeshipText = document.getElementById('cart-freeship-text');
  const freeshipFill = document.getElementById('cart-freeship-fill');
  const freeshipTrack = freeship?.querySelector<HTMLElement>('.cart-freeship-track') ?? null;

  function renderFreeShip(cart: Cart | null) {
    if (!freeship) return;
    const lines = cart?.lines ?? [];
    if (!cart || lines.length === 0) {
      freeship.style.display = 'none';
      return;
    }
    freeship.style.display = 'block';
    const { amount, currencyCode } = cart.cost.subtotalAmount;
    const { qualified, remaining, pct } = freeShipProgress(Number(amount));
    freeship.classList.toggle('is-qualified', qualified);
    if (freeshipText) {
      freeshipText.innerHTML = qualified
        ? "🎉 You've unlocked <strong>free shipping</strong>!"
        : 'Add <strong>' + formatMoney(remaining, currencyCode) + '</strong> more for free shipping';
    }
    if (freeshipFill) freeshipFill.style.width = pct + '%';
    if (freeshipTrack) freeshipTrack.setAttribute('aria-valuenow', String(Math.round(pct)));
  }

  const esc = (s: unknown) =>
    String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] as string);

  const lineMeta = (line: CartLine) =>
    (line.merchandise.selectedOptions || [])
      .filter((o) => o.value && o.value.toLowerCase() !== 'default title')
      .map((o) => '<div class="cart-item-meta">' + esc(o.name) + ': ' + esc(o.value) + '</div>')
      .join('');

  function render(cart: Cart | null) {
    if (!itemsList) return;
    const lines = cart?.lines ?? [];
    renderFreeShip(cart);
    void renderUpsell(upsellEl, cart, { limit: 3 });

    if (lines.length === 0) {
      itemsList.style.display = 'none';
      itemsList.innerHTML = '';
      if (emptyState) emptyState.style.display = 'flex';
      if (footer) footer.style.display = 'none';
      return;
    }

    itemsList.style.display = 'flex';
    if (emptyState) emptyState.style.display = 'none';
    if (footer) footer.style.display = 'block';

    itemsList.innerHTML = lines
      .map((line) => {
        const m = line.merchandise;
        const image = m.image?.url || m.product?.featuredImage?.url || '';
        const name = m.product?.title || m.title || '';
        const unit = formatMoney(
          Number(line.cost.amountPerQuantity.amount),
          line.cost.amountPerQuantity.currencyCode,
        );
        return (
          '<div class="cart-item">' +
            '<img src="' + esc(sizedImg(image, 200)) + '" class="cart-item-image" alt="' + esc(name) + '" loading="lazy" />' +
            '<div class="cart-item-info">' +
              '<div class="cart-item-name">' + esc(name) + '</div>' +
              '<div class="cart-item-price">' + unit + '</div>' +
              lineMeta(line) +
              '<button class="cart-remove-btn" data-action="remove" data-line="' + esc(line.id) + '">Remove</button>' +
            '</div>' +
            '<div class="cart-item-qty-col">' +
              '<button class="cart-qty-btn" data-action="inc" data-line="' + esc(line.id) + '">+</button>' +
              '<span class="cart-qty-value">' + line.quantity + '</span>' +
              '<button class="cart-qty-btn" data-action="dec" data-line="' + esc(line.id) + '">−</button>' +
            '</div>' +
          '</div>'
        );
      })
      .join('');

    if (subtotalEl && cart) {
      subtotalEl.textContent = formatMoney(
        Number(cart.cost.subtotalAmount.amount),
        cart.cost.subtotalAmount.currencyCode,
      );
    }
    if (checkoutBtn && cart) checkoutBtn.href = cart.checkoutUrl || '#';

    itemsList.querySelectorAll<HTMLElement>('[data-action]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const lineId = btn.getAttribute('data-line') || '';
        const action = btn.getAttribute('data-action');
        const line = getCurrentCart()?.lines.find((l) => l.id === lineId);
        if (!line) return;
        if (action === 'inc') updateLine(lineId, line.quantity + 1);
        else if (action === 'dec') updateLine(lineId, line.quantity - 1);
        else if (action === 'remove') removeLine(lineId);
      });
    });
  }

  window.addEventListener('cart:updated', (e) => render((e as CustomEvent).detail.cart));
  render(getCurrentCart());
  initCart();
</script>

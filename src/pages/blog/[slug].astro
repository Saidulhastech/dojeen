1.5434 19.0378 11.9035 19.3946C12.2636 19.7514 12.7511 19.9517 13.2592 19.9517H15.0126C15.5323 19.9519 16.0469 19.8502 16.5271 19.6525C17.0073 19.4547 17.4436 19.1647 17.8112 18.7991C18.1788 18.4335 18.4704 17.9994 18.6694 17.5215C18.8684 17.0437 18.9708 16.5316 18.9709 16.0144L18.9795 8.00698Z" fill="currentColor"></path>
                    </g>
                    <defs>
                      <clipPath id="clip0_post_home">
                        <rect width="19" height="20" fill="white"></rect>
                      </clipPath>
                    </defs>
                  </svg>
                </div>
                <div class="button-text">Back to Home</div>
              </div>
              <div class="button-bg secondary"></div>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- Related Articles -->
    {relatedPosts.length > 0 && (
      <section class="blog-section">
        <div class="section-gap-bottom">
          <div class="w-layout-blockcontainer container-default w-container">
            <div class="section-title-block center">
              <div class="section-title-inner blog">
                <div class="section-subtitle">Keep Reading</div>
                <h2 class="section-title">Related Articles</h2>
              </div>
            </div>
            <div class="blog-list-wrapper w-dyn-list">
              <div role="list" class="blog-list w-dyn-items">
                {relatedPosts.map((p) => (
                  <div role="listitem" class="blog-list-item w-dyn-item">
                    <BlogCard post={p} headingTag="h3" />
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

  </main>
  <Footer />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import BlogCard from '@/components/sections/BlogCard.astro';
import { posts } from '@/data/blog';
import type { Post } from '@/types';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

interface Props {
  post: Post;
}

const { post } = Astro.props;
const categorySlug = post.category.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and');

// Related posts: same category first, then fill with recent posts; max 3
const relatedPosts = [
  ...posts.filter((p) => p.category === post.category && p.slug !== post.slug),
  ...posts.filter((p) => p.category !== post.category && p.slug !== post.slug),
].slice(0, 3);
---

<BaseLayout title={`${post.title} — Dojeen Blog`} description={post.excerpt}>
  <Header variant="default" currentPath={Astro.url.pathname} />
  <main class="main-wrapper">

    <section class="blog-details-section page-top-gap">
      <div class="cms-hero-gap">
        <div class="w-layout-blockcontainer container-default w-container">

          <!-- Post Image -->
          <div class="blog-main-image-block">
            <img
              src={`/images/${post.thumbnail}`}
              loading="lazy"
              alt="Blog Image"
              class="blog-image"
            />
          </div>

          <!-- Header: Meta + Title -->
          <div class="blog-details-header-block">
            <div class="blog-details-meta-wrapper">
              <div class="blog-meta-block">
                <img loading="lazy" src="/images/blog-meta-icon-1.svg" alt="Blog Meta Icon" class="blog-meta-icon" />
                <div class="blog-meta-text">{post.date}</div>
              </div>
              <div class="blog-meta-separator"></div>
              <a href={`/blog/category/${categorySlug}`} class="blog-meta-link-block w-inline-block">
                <img loading="lazy" src="/images/blog-meta-icon-2.svg" alt="Blog Meta Icon" class="blog-meta-icon" />
                <div class="blog-meta-text">{post.category}</div>
              </a>
            </div>
            <div class="blog-title-inner">
              <h1 class="blog-main-title">{post.title}</h1>
            </div>
          </div>

          <!-- Rich Text Content -->
          <div class="blog-details-rich-text w-richtext" set:html={post.content} />

          <!-- Back to Home -->
          <div class="button-wrapper center">
            <a href="/" class="secondary-button border-color w-inline-block">
              <div class="button-text-block">
                <div class="w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="19" height="20" viewBox="0 0 19 20" fill="none">
                    <g clip-path="url(#clip0_post_home)">

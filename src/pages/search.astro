---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CommonHero from '@/components/ui/CommonHero.astro';
import { products } from '@/data/products';

const allProductsJSON = JSON.stringify(products.map((p) => ({
  slug: p.slug,
  name: p.name,
  price: p.price,
  category: p.category,
  thumbnail: p.thumbnail,
  isOnSale: p.isOnSale,
  discount: p.discount,
  comparePrice: p.comparePrice,
})));
---

<BaseLayout title="Search — Dojeen" description="Search for products on Dojeen.">
  <Header variant="default" />
  <main class="main-wrapper">

    <CommonHero subtitle="Search" title="Search Products" />

    <section class="search-results-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">

          <!-- Search Form -->
          <form action="/search" method="get" class="search-page-form">
            <div class="search-page-bar">
              <input
                type="search"
                name="q"
                id="searchPageInput"
                placeholder="Search products..."
                class="search-page-bar-input"
                autocomplete="off"
              />
              <button type="submit" class="search-page-bar-btn" aria-label="Search">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12.5947 12.5947C12.8875 12.3018 13.3624 12.3018 13.6553 12.5947L17.0303 15.9697C17.3232 16.2625 17.3232 16.7374 17.0303 17.0303C16.7374 17.3232 16.2625 17.3232 15.9697 17.0303L12.5947 13.6553C12.3018 13.3624 12.3018 12.8875 12.5947 12.5947Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M0.75 8.25C0.75 4.10786 4.10786 0.75 8.25 0.75C12.3921 0.75 15.75 4.10786 15.75 8.25C15.75 12.3921 12.3921 15.75 8.25 15.75C4.10786 15.75 0.75 12.3921 0.75 8.25ZM8.25 2.25C4.93629 2.25 2.25 4.93629 2.25 8.25C2.25 11.5637 4.93629 14.25 8.25 14.25C11.5637 14.25 14.25 11.5637 14.25 8.25C14.25 4.93629 11.5637 2.25 8.25 2.25Z" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </form>

          <!-- Results grid (same classes as shop page) -->
          <div class="product-collection-list w-dyn-list">
            <div id="searchResults" role="list" class="product-archive-grid-two w-dyn-items"></div>
          </div>
          <div id="searchEmpty" class="search-empty-state" style="display:none">
            <p>No products found matching your search. <a href="/shop">Browse all products</a></p>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script is:inline define:vars={{ allProductsJSON }}>
  (function () {
    var allProducts = JSON.parse(allProductsJSON);
    var resultsEl  = document.getElementById('searchResults');
    var emptyEl    = document.getElementById('searchEmpty');
    var inputEl    = document.getElementById('searchPageInput');
    var heroTitle  = document.querySelector('.common-hero-title');

    // Read query at runtime — Astro.url is always empty in SSG at build time
    var params = new URLSearchParams(window.location.search);
    var query  = params.get('q') || params.get('query') || '';

    // Pre-fill the search input
    if (inputEl && query) inputEl.value = query;

    // Update hero title + document title
    if (query) {
      if (heroTitle) heroTitle.textContent = 'Results for “' + query + '”';
      document.title = 'Search: “' + query + '” — Dojeen';
    }

    function renderProduct(p) {
      var priceHTML = p.isOnSale
        ? '<div class="product-card-sale-price">$' + p.price.toFixed(2) + '</div>' +
          '<div class="product-carrd-compare-price">$' + (p.comparePrice || p.price).toFixed(2) + '</div>'
        : '<div class="product-card-discount-price">$' + p.price.toFixed(2) + '</div>';
      var badgeHTML = p.isOnSale
        ? '<div class="product-badge-wrapper"><div class="sale-badge">Sale</div>' +
          (p.discount ? '<div class="discount-badge">-' + p.discount + '%</div>' : '') + '</div>'
        : '';
      return (
        '<div role="listitem" class="product-collection-item w-dyn-item">' +
          '<div class="product-card-block">' +
            '<div class="offerse-card-block">' +
              '<div class="product-tab-wrapper">' +
                '<a href="/products/' + p.slug + '" class="product-thumbnail-block w-inline-block">' +
                  '<img loading="lazy" src="/images/' + p.thumbnail + '" alt="' + p.name + '" class="product-main-thumbnail" />' +
                '</a>' +
                badgeHTML +
              '</div>' +
              '<div class="product-card-info-block">' +
                '<a href="/products/' + p.slug + '" class="product-link-block w-inline-block">' +
                  '<h3 class="product-name">' + p.name + '</h3>' +
                '</a>' +
                '<div class="product-card-pricing-block">' + priceHTML + '</div>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>'
      );
    }

    function doSearch(q) {
      if (!q) {
        if (resultsEl) resultsEl.innerHTML = '';
        if (emptyEl) emptyEl.style.display = 'none';
        return;
      }
      var lower = q.toLowerCase();
      var filtered = allProducts.filter(function (p) {
        return p.name.toLowerCase().indexOf(lower) !== -1 ||
               p.category.toLowerCase().indexOf(lower) !== -1;
      });
      if (filtered.length > 0) {
        if (resultsEl) resultsEl.innerHTML = filtered.map(renderProduct).join('');
        if (emptyEl)   emptyEl.style.display = 'none';
      } else {
        if (resultsEl) resultsEl.innerHTML = '';
        if (emptyEl)   emptyEl.style.display = '';
      }
    }

    doSearch(query);
  })();
</script>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CommonHero from '@/components/ui/CommonHero.astro';
import ProductCard from '@/components/sections/ProductCard.astro';
import { searchProducts, SEARCH_SORT_OPTIONS, resolveSort } from '@/lib/shopify';
import { adaptCard } from '@/lib/shopify/adapter';
import type { Product } from '@/types';

export const prerender = false;

const PAGE_SIZE = 24;
const params = Astro.url.searchParams;

// Header forms submit `query`; the search page form submits `q`. Accept both.
const q = (params.get('q') ?? params.get('query') ?? '').trim();
const sort = resolveSort(SEARCH_SORT_OPTIONS, params.get('sort'));
const after = params.get('after');
const before = params.get('before');

let results: Product[] = [];
let total = 0;
let pageInfo: { hasNextPage: boolean; hasPreviousPage: boolean; startCursor?: string | null; endCursor?: string | null } = {
  hasNextPage: false,
  hasPreviousPage: false,
  startCursor: null,
  endCursor: null,
};
if (q) {
  try {
    const res = await searchProducts({
      query: q,
      pageSize: PAGE_SIZE,
      sortKey: sort.sortKey,
      reverse: sort.reverse,
      after,
      before,
    });
    results = res.items.map(adaptCard);
    total = res.totalCount;
    pageInfo = res.pageInfo;
  } catch {
    /* network/Shopify error — surface the empty state */
  }
}

// Build a URL preserving q + sort with the given overrides (null = remove).
function buildUrl(overrides: Record<string, string | null>): string {
  const sp = new URLSearchParams();
  if (q) sp.set('q', q);
  if (sort.value !== SEARCH_SORT_OPTIONS[0].value) sp.set('sort', sort.value);
  for (const [k, v] of Object.entries(overrides)) {
    if (v == null) sp.delete(k);
    else sp.set(k, v);
  }
  const qs = sp.toString();
  return Astro.url.pathname + (qs ? `?${qs}` : '');
}

const nextUrl = pageInfo.hasNextPage && pageInfo.endCursor ? buildUrl({ after: pageInfo.endCursor }) : null;
const prevUrl = pageInfo.hasPreviousPage && pageInfo.startCursor ? buildUrl({ before: pageInfo.startCursor }) : null;

const heroTitle = q ? `Results for “${q}”` : 'Search Products';
---

<BaseLayout
  title={q ? `Search: “${q}” — Dojeen` : 'Search — Dojeen'}
  description="Search for products on Dojeen."
>
  <Header variant="default" />
  <main id="main-content" class="main-wrapper">

    <CommonHero subtitle="Search" title={heroTitle} />

    <section class="search-results-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">

          <!-- Search Form -->
          <form action="/search" method="get" class="search-page-form">
            <div class="search-page-bar">
              <input
                type="search"
                name="q"
                id="searchPageInput"
                value={q}
                placeholder="Search products..."
                class="search-page-bar-input"
                autocomplete="off"
              />
              <button type="submit" class="search-page-bar-btn" aria-label="Search">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M12.5947 12.5947C12.8875 12.3018 13.3624 12.3018 13.6553 12.5947L17.0303 15.9697C17.3232 16.2625 17.3232 16.7374 17.0303 17.0303C16.7374 17.3232 16.2625 17.3232 15.9697 17.0303L12.5947 13.6553C12.3018 13.3624 12.3018 12.8875 12.5947 12.5947Z" fill="currentColor"/>
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M0.75 8.25C0.75 4.10786 4.10786 0.75 8.25 0.75C12.3921 0.75 15.75 4.10786 15.75 8.25C15.75 12.3921 12.3921 15.75 8.25 15.75C4.10786 15.75 0.75 12.3921 0.75 8.25ZM8.25 2.25C4.93629 2.25 2.25 4.93629 2.25 8.25C2.25 11.5637 4.93629 14.25 8.25 14.25C11.5637 14.25 14.25 11.5637 14.25 8.25C14.25 4.93629 11.5637 2.25 8.25 2.25Z" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </form>

          {q && results.length > 0 && (
            <div class="product-selector-form-block w-form">
              <div class="shop-result-info">
                <span class="selector-text">{total} {total === 1 ? 'result' : 'results'} for “{q}”</span>
              </div>
              <form method="get" action="/search" id="searchSortForm" class="product-selector-form">
                <input type="hidden" name="q" value={q} />
                <div class="selector-text">Sort by:</div>
                <select id="searchSortSelect" name="sort" class="product-select-input w-select">
                  {SEARCH_SORT_OPTIONS.map((opt) => (
                    <option value={opt.value} selected={opt.value === sort.value}>{opt.label}</option>
                  ))}
                </select>
              </form>
            </div>
          )}

          {results.length > 0 ? (
            <div class="product-collection-list w-dyn-list">
              <div role="list" class="product-archive-grid-two w-dyn-items">
                {results.map((product) => (
                  <div role="listitem" class="product-collection-item w-dyn-item">
                    <div class="product-card-block">
                      <ProductCard product={product} headingTag="h3" />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <div class="search-empty-state">
              {q ? (
                <p>No products found for “{q}”. <a href="/shop">Browse all products</a></p>
              ) : (
                <p>Type a search term above to find products.</p>
              )}
            </div>
          )}

          {(nextUrl || prevUrl) && (
            <div class="plp-pagination">
              {prevUrl ? (
                <a href={prevUrl} class="plp-page-btn" rel="prev">← Previous</a>
              ) : (
                <span class="plp-page-btn is-disabled" aria-disabled="true">← Previous</span>
              )}
              {nextUrl ? (
                <a href={nextUrl} class="plp-page-btn" rel="next">Next →</a>
              ) : (
                <span class="plp-page-btn is-disabled" aria-disabled="true">Next →</span>
              )}
            </div>
          )}

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  .plp-pagination {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
  }
  .plp-page-btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border: 1px solid var(--_color---neutral-400);
    border-radius: var(--_border-radius---radius-xs);
    font-size: 15px;
    color: var(--_color---neutral-800);
    background: #fff;
    transition: background-color .2s ease, border-color .2s ease;
  }
  .plp-page-btn:hover {
    border-color: var(--_color---neutral-800);
  }
  .plp-page-btn.is-disabled {
    color: var(--_color---neutral-500);
    background: var(--_color---neutral-200);
    pointer-events: none;
  }
</style>

<script is:inline>
  /* Auto-submit search sort form on change (resets cursor — new form has no after/before). */
  (function () {
    var sel = document.getElementById('searchSortSelect');
    var form = document.getElementById('searchSortForm');
    if (sel && form) sel.addEventListener('change', function () { form.submit(); });
  })();
</script>

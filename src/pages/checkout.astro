---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CommonHero from '@/components/ui/CommonHero.astro';
---

<BaseLayout title="Checkout — Dojeen" description="Complete your order.">
  <Header variant="default" />
  <main class="main-wrapper">

    <CommonHero subtitle="Checkout" title="Complete Your Order" />

    <div class="checkout-area">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">

          <form id="checkoutForm" class="checkout-layout">

            <!-- ── LEFT: form blocks ── -->
            <div class="checkout-main">

              <!-- Contact Information -->
              <div class="checkout-block">
                <div class="checkout-block-header">
                  <h2 class="checkout-block-title">Contact Information</h2>
                  <span class="checkout-req-note">* Required</span>
                </div>
                <div class="checkout-block-body">
                  <div class="checkout-row">
                    <div class="checkout-field">
                      <label class="checkout-label" for="firstName">First Name *</label>
                      <input type="text" id="firstName" name="firstName" required placeholder="First name" class="checkout-input" />
                    </div>
                    <div class="checkout-field">
                      <label class="checkout-label" for="lastName">Last Name *</label>
                      <input type="text" id="lastName" name="lastName" required placeholder="Last name" class="checkout-input" />
                    </div>
                  </div>
                  <div class="checkout-field">
                    <label class="checkout-label" for="email">Email Address *</label>
                    <input type="email" id="email" name="email" required placeholder="your@email.com" class="checkout-input" />
                  </div>
                  <div class="checkout-field no-mb">
                    <label class="checkout-label" for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000" class="checkout-input" />
                  </div>
                </div>
              </div>

              <!-- Shipping Address -->
              <div class="checkout-block">
                <div class="checkout-block-header">
                  <h2 class="checkout-block-title">Shipping Address</h2>
                  <span class="checkout-req-note">* Required</span>
                </div>
                <div class="checkout-block-body">
                  <div class="checkout-field">
                    <label class="checkout-label" for="address">Street Address *</label>
                    <input type="text" id="address" name="address" required placeholder="123 Main St" class="checkout-input" />
                  </div>
                  <div class="checkout-row">
                    <div class="checkout-field">
                      <label class="checkout-label" for="city">City *</label>
                      <input type="text" id="city" name="city" required placeholder="City" class="checkout-input" />
                    </div>
                    <div class="checkout-field">
                      <label class="checkout-label" for="state">State / Province</label>
                      <input type="text" id="state" name="state" placeholder="State" class="checkout-input" />
                    </div>
                  </div>
                  <div class="checkout-row">
                    <div class="checkout-field">
                      <label class="checkout-label" for="zip">ZIP / Postal Code</label>
                      <input type="text" id="zip" name="zip" placeholder="ZIP" class="checkout-input" />
                    </div>
                    <div class="checkout-field no-mb">
                      <label class="checkout-label" for="country">Country *</label>
                      <select id="country" name="country" class="checkout-input checkout-select">
                        <option value="">Select country</option>
                        <option value="US">United States</option>
                        <option value="GB">United Kingdom</option>
                        <option value="CA">Canada</option>
                        <option value="AU">Australia</option>
                        <option value="DE">Germany</option>
                        <option value="FR">France</option>
                        <option value="NL">Netherlands</option>
                        <option value="SG">Singapore</option>
                        <option value="AE">United Arab Emirates</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Payment Information -->
              <div class="checkout-block">
                <div class="checkout-block-header">
                  <h2 class="checkout-block-title">Payment Information</h2>
                  <span class="checkout-req-note">* Required</span>
                </div>
                <div class="checkout-block-body">
                  <div class="checkout-field">
                    <label class="checkout-label" for="cardNumber">Card Number *</label>
                    <input type="text" id="cardNumber" name="cardNumber" placeholder="•••• •••• •••• ••••" maxlength="19" class="checkout-input" />
                  </div>
                  <div class="checkout-row">
                    <div class="checkout-field">
                      <label class="checkout-label" for="expiry">Expiry Date *</label>
                      <input type="text" id="expiry" name="expiry" placeholder="MM / YY" maxlength="7" class="checkout-input" />
                    </div>
                    <div class="checkout-field">
                      <label class="checkout-label" for="cvv">Security Code *</label>
                      <input type="text" id="cvv" name="cvv" placeholder="CVV" maxlength="4" class="checkout-input" />
                    </div>
                  </div>
                  <div class="checkout-billing-toggle">
                    <input type="checkbox" id="billingSame" checked class="checkout-checkbox" />
                    <label for="billingSame" class="checkout-checkbox-label">Billing address same as shipping</label>
                  </div>
                </div>
              </div>

              <!-- Items in Order -->
              <div class="checkout-block">
                <div class="checkout-block-header">
                  <h2 class="checkout-block-title">Items in Order</h2>
                </div>
                <div class="checkout-block-body" id="checkoutCartItems">
                  <p class="checkout-empty-cart">Your cart is empty. <a href="/shop">Continue shopping</a></p>
                </div>
              </div>

            </div>

            <!-- ── RIGHT: sticky order summary ── -->
            <div class="checkout-sidebar">
              <div class="checkout-block checkout-summary-block">
                <div class="checkout-block-header">
                  <h2 class="checkout-block-title">Order Summary</h2>
                </div>
                <div class="checkout-block-body">
                  <div class="checkout-summary-line">
                    <span>Subtotal</span>
                    <span id="checkoutSubtotal">$0.00</span>
                  </div>
                  <div class="checkout-summary-line">
                    <span>Shipping</span>
                    <span class="checkout-free">Free</span>
                  </div>
                  <div class="checkout-summary-divider"></div>
                  <div class="checkout-summary-line checkout-summary-total">
                    <strong>Total</strong>
                    <strong id="checkoutTotal">$0.00</strong>
                  </div>
                </div>
              </div>

              <button type="submit" class="primary-button w-inline-block checkout-place-order">
                <div class="button-text-block">
                  <div class="button-text">Place Order</div>
                </div>
                <div class="button-bg"></div>
              </button>
            </div>

          </form>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  (function () {
    function loadCart() {
      try { return JSON.parse(localStorage.getItem('dojeen_cart') || '[]'); } catch (e) { return []; }
    }

    function renderCartItems() {
      var cart = loadCart();
      var container = document.getElementById('checkoutCartItems');
      var subtotalEl = document.getElementById('checkoutSubtotal');
      var totalEl    = document.getElementById('checkoutTotal');
      if (!container) return;

      if (cart.length === 0) {
        container.innerHTML = '<p class="checkout-empty-cart">Your cart is empty. <a href="/shop">Continue shopping</a></p>';
        return;
      }

      var total = 0;
      container.innerHTML = cart.map(function (item) {
        total += item.price * item.quantity;
        return (
          '<div class="checkout-item">' +
            '<img src="' + (item.image || '') + '" alt="' + item.name + '" class="checkout-item-thumb" />' +
            '<div class="checkout-item-info">' +
              '<div class="checkout-item-name">' + item.name + '</div>' +
              (item.size  ? '<div class="checkout-item-meta">Size: '  + item.size  + '</div>' : '') +
              (item.color ? '<div class="checkout-item-meta">Color: ' + item.color + '</div>' : '') +
              '<div class="checkout-item-meta">Qty: ' + item.quantity + '</div>' +
            '</div>' +
            '<div class="checkout-item-price">$' + (item.price * item.quantity).toFixed(2) + '</div>' +
          '</div>'
        );
      }).join('');

      if (subtotalEl) subtotalEl.textContent = '$' + total.toFixed(2);
      if (totalEl)    totalEl.textContent    = '$' + total.toFixed(2);
    }

    renderCartItems();

    var form = document.getElementById('checkoutForm');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        localStorage.removeItem('dojeen_cart');
        window.dispatchEvent(new CustomEvent('cart:updated', { detail: { items: [] } }));
        window.location.href = '/order-confirmation';
      });
    }
  })();
</script>

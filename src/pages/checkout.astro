---
// Checkout is handled by Shopify's hosted checkout. Send the buyer
// straight to the current cart's checkoutUrl; if the cart is empty
// or expired, bounce back to the cart page.
import { readCart } from '@/lib/cart-server';

export const prerender = false;

const { cart } = await readCart(Astro.cookies, Astro.clientAddress);

if (cart?.checkoutUrl && cart.totalQuantity > 0) {
  return Astro.redirect(cart.checkoutUrl, 303);
}
return Astro.redirect('/cart', 303);
---

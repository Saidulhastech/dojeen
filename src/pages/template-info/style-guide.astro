                  <img loading="lazy" src="/images/why-choose-us-1.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/why-choose-us-3.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/why-choose-us-2.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/blog-meta-icon-1.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/blog-meta-icon-2.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/breadcrumb-icon.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/product-accordion-icon-3.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/product-accordion-icon-1.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/product-accordion-icon-2.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/accordion-arrow.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/product-accordion-icon-1.svg" alt="Style Guide Icon" class="style-guide-icon" />
                  <img loading="lazy" src="/images/selector-icon.svg" alt="Style Guide Icon" class="style-guide-icon" />
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CommonHero from '@/components/ui/CommonHero.astro';
---

<BaseLayout title="Style Guide | Dojeen" description="Color palette, typography, buttons, and icon inventory for the Dojeen template." noIndex={true}>
  <Header variant="default" />
  <main class="main-wrapper">

    <CommonHero
      subtitle="Style Guide"
      title="Style Guide for Dojeen Template"
      titleBlockClass="style-guide"
      sectionClass="page-top-gap"
    />

    <section class="style-guide-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="style-guide-grid">

            <!-- Sidebar -->
            <div id="w-node-_06186a91-ca32-2900-768a-e1e6f85a485f-34f3a516" class="style-guide-sidebar">
              <div class="style-gulde-link-wrapper">
                <a href="#colors" class="style-guide-link">Colors</a>
                <a href="#typography" class="style-guide-link">Typography</a>
                <a href="#buttons" class="style-guide-link">Buttons</a>
                <a href="#Icons" class="style-guide-link">Icons</a>
              </div>
            </div>

            <!-- Content -->
            <div class="style-guide-content-wrapper">

              <!-- Colors -->
              <div id="colors" class="color-wrapper">
                <div class="style-guide-heading-wrapper">
                  <h2 class="style-guide-heading">Colors</h2>
                </div>
                <div class="typography-details-wrapper">
                  <div class="style-guide-color-grid">
                    <div id="w-node-_06186a91-ca32-2900-768a-e1e6f85a489d-34f3a516" class="color-card">
                      <div class="color-block white-color"></div>
                      <div class="color-details-block">
                        <div class="color-heading">White color</div>
                        <p class="color-code">#Ffffff</p>
                      </div>
                    </div>
                    <div id="w-node-_06186a91-ca32-2900-768a-e1e6f85a4870-34f3a516" class="color-card">
                      <div class="color-block neutral-100"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 100</div>
                        <p class="color-code">#f9f9f8</p>
                      </div>
                    </div>
                    <div id="w-node-_06186a91-ca32-2900-768a-e1e6f85a487e-34f3a516" class="color-card">
                      <div class="color-block neutral-150"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 150</div>
                        <p class="color-code">#f8f8f8</p>
                      </div>
                    </div>
                    <div id="w-node-c1a7e456-58e1-f73c-94bd-719a8883e496-34f3a516" class="color-card">
                      <div class="color-block neutral-200"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 200</div>
                        <p class="color-code">#f7f7f7</p>
                      </div>
                    </div>
                    <div id="w-node-_06186a91-ca32-2900-768a-e1e6f85a4877-34f3a516" class="color-card">
                      <div class="color-block neutral-300"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 300</div>
                        <p class="color-code">#f2f2f2</p>
                      </div>
                    </div>
                    <div id="w-node-_06186a91-ca32-2900-768a-e1e6f85a488c-34f3a516" class="color-card">
                      <div class="color-block neutral-400"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 400</div>
                        <p class="color-code">#e5e8ec</p>
                      </div>
                    </div>
                    <div id="w-node-cb5ffcc3-373c-8d80-efd7-822cfaa53f9a-34f3a516" class="color-card">

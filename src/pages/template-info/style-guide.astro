                        <div class="color-heading">Neutral 450</div>
                        <p class="color-code">#e1d8c3</p>
                      </div>
                    </div>
                    <div id="w-node-bb3b18b1-c354-fb32-c2f1-f5ceab6b4fc1-34f3a516" class="color-card">
                      <div class="color-block neutral-500"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 500</div>
                        <p class="color-code">#9b9b9b</p>
                      </div>
                    </div>
                    <div id="w-node-c8ffec8e-c67d-dafc-9989-3b2e60da0539-34f3a516" class="color-card">
                      <div class="color-block neutral-600"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 600</div>
                        <p class="color-code">#3b3b3b</p>
                      </div>
                    </div>
                    <div id="w-node-fe62889d-b4f9-04f8-8816-6a02dfc131ed-34f3a516" class="color-card">
                      <div class="color-block neutral-700"></div>
                      <div class="color-details-block">
                        <div class="color-heading">Neutral 700</div>

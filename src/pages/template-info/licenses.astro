---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CommonHero from '@/components/ui/CommonHero.astro';
---

<BaseLayout title="Licenses — Dojeen" description="License information for assets used in the Dojeen template." noIndex={true}>
  <Header variant="default" />
  <main class="main-wrapper">

    <CommonHero subtitle="Licenses" title="Asset Licenses & Credits" />

    <section class="licenses-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="license-wrapper">

            <div class="license-content">
              <div class="license-heading">Images</div>
              <p class="license-paragraph">All images are sourced from Freepik. Find the Freepik license information here.</p>
              <a href="https://www.freepikcompany.com/legal#nav-freepik-license" target="_blank" rel="noopener" class="read-more-link w-inline-block">
                <div>Read More</div>
                <div class="link-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M20 12L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M15 7C15 7 20 10.6824 20 12C20 13.3176 15 17 15 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </div>
              </a>
            </div>

            <div class="license-content">
              <div class="license-heading">Icons</div>
              <p class="license-paragraph">The Dojeen template uses SVG image format for all icon fonts. Find license information here.</p>
              <a href="https://www.flaticon.com/" target="_blank" rel="noopener" class="read-more-link w-inline-block">
                <div>Read More</div>
                <div class="link-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M20 12L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M15 7C15 7 20 10.6824 20 12C20 13.3176 15 17 15 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </div>
              </a>
            </div>

            <div class="license-content">
              <div class="license-heading">Font</div>
              <p class="license-paragraph">The Dojeen template uses Google Fonts. Find Instrument Sans and Inter font license info here.</p>
              <div class="template-info-link-wrapper">
                <a href="https://fonts.google.com/specimen/Instrument+Sans" target="_blank" rel="noopener" class="read-more-link w-inline-block">
                  <div>Instrument Sans</div>
                  <div class="link-icon w-embed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M20 12L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M15 7C15 7 20 10.6824 20 12C20 13.3176 15 17 15 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>
                </a>
                <a href="https://fonts.google.com/specimen/Inter" target="_blank" rel="noopener" class="read-more-link w-inline-block">
                  <div>Inter</div>
                  <div class="link-icon w-embed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M20 12L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path d="M15 7C15 7 20 10.6824 20 12C20 13.3176 15 17 15 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

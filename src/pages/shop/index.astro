---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CommonHero from '@/components/ui/CommonHero.astro';
import ProductCard from '@/components/sections/ProductCard.astro';
import { img } from '@/lib/img';
import { formatMoney } from '@/lib/money';
import { getShopProducts, getCategoryFaceted, getCategories, getBestSellers } from '@/lib/catalog';
import { SHOP_SORT_OPTIONS, resolveShopSort } from '@/lib/shopify';
import { buildFacetChips } from '@/lib/facet-chips';
import { features } from '@/data/features';

export const prerender = false;

const PAGE_SIZE = 24;
const params = Astro.url.searchParams;

// ── Product Type (collection) selection ──
const categories = await getCategories();
const categoryParam = params.get('category');
const activeCat = categories.find((c) => c.slug === categoryParam) ?? null;

// ── Sort (one UI list, mapped per data source) ──
const sort = resolveShopSort(params.get('sort'));

// ── Facet filters → Shopify ProductFilter inputs ──
const selectedFilterInputs = params.getAll('filter');
const filters: unknown[] = [];
for (const raw of selectedFilterInputs) {
  try {
    filters.push(JSON.parse(raw));
  } catch {
    /* skip malformed filter param */
  }
}
const priceMin = params.get('price_min');
const priceMax = params.get('price_max');
const price: { min?: number; max?: number } = {};
if (priceMin && Number.isFinite(Number(priceMin))) price.min = Number(priceMin);
if (priceMax && Number.isFinite(Number(priceMax))) price.max = Number(priceMax);
if (price.min != null || price.max != null) filters.push({ price });

// ── Cursor pagination ──
const after = params.get('after');
const before = params.get('before');

// Collection-backed when a Product Type is chosen, else search-backed (all products).
const data = activeCat
  ? await getCategoryFaceted(activeCat.slug, {
      limit: PAGE_SIZE,
      sortKey: sort.collection.sortKey,
      reverse: sort.collection.reverse,
      filters: filters.length ? filters : undefined,
      after,
      before,
    })
  : await getShopProducts({
      limit: PAGE_SIZE,
      sortKey: sort.search.sortKey,
      reverse: sort.search.reverse,
      filters: filters.length ? filters : undefined,
      after,
      before,
    });

// Invalid ?category falls back to all products.
const source = data ?? (await getShopProducts({ limit: PAGE_SIZE }));
const products = source.items;
const facets = source.filters;
const pageInfo = source.pageInfo;
const resultCount = activeCat ? products.length : source.totalCount;
const activeFilterCount = filters.length;
const chips = buildFacetChips({
  facets,
  selectedFilterInputs,
  priceMin,
  priceMax,
  currencyCode: products[0]?.currencyCode,
  pathname: Astro.url.pathname,
  search: Astro.url.search,
});

// Sidebar/secondary sections (independent of the active filter state).
const bestSellers = await getBestSellers(4);
const popularProducts = bestSellers.slice(0, 3);

// Build a URL on /shop with the given overrides; null removes the param.
function buildUrl(overrides: Record<string, string | null>): string {
  const sp = new URLSearchParams(params.toString());
  sp.delete('after');
  sp.delete('before');
  for (const [k, v] of Object.entries(overrides)) {
    if (v == null) sp.delete(k);
    else sp.set(k, v);
  }
  const qs = sp.toString();
  return '/shop' + (qs ? `?${qs}` : '');
}

const nextUrl = pageInfo.hasNextPage && pageInfo.endCursor ? buildUrl({ after: pageInfo.endCursor }) : null;
const prevUrl = pageInfo.hasPreviousPage && pageInfo.startCursor ? buildUrl({ before: pageInfo.startCursor }) : null;
const clearUrl = activeCat ? `/shop?category=${activeCat.slug}` : '/shop';
---

<BaseLayout title="Shop — Dojeen" description="Browse our full collection of sustainable fashion pieces.">
  <Header variant="default" currentPath="/shop" />
  <main id="main-content" class="main-wrapper">

    <CommonHero subtitle="Explore our product" title={activeCat ? activeCat.name : 'Our Product Collection'} />

    <section class="product-archive-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">

          <form method="get" action="/shop" id="facetForm" class="product-wrapper-with-sidebar">
            {/* Hidden category keeps the Product Type selection when a facet/sort change submits the form. */}
            {activeCat && <input type="hidden" name="category" value={activeCat.slug} />}

            <!-- Sidebar -->
            <div class="product-sidbar-main">
              <div class="product-sidebar-mobile-accordion">
                <button type="button" class="product-filter" id="sidebarToggle" aria-expanded="false" aria-controls="sidebarInner" aria-haspopup="dialog">
                  <div class="product-sidebar-accordion-text">
                    Filter{activeFilterCount > 0 ? ` (${activeFilterCount})` : ''}
                  </div>
                  <img src="/images/accordion-arrow.svg" loading="lazy" alt="Filter Arrow" class="product-sidebar-accordion-arrow" />
                </button>
              </div>

              <!-- Mobile drawer overlay (hidden on desktop) -->
              <div class="filter-drawer-overlay" id="filterDrawerOverlay" data-filter-close></div>

              <div class="product-sidebar-inner-wrapper" id="sidebarInner" aria-label="Product filters">
                <!-- Drawer header (mobile only) -->
                <div class="filter-drawer-head">
                  <span class="filter-drawer-title">Filters</span>
                  <button type="button" class="filter-drawer-close" data-filter-close aria-label="Close filters">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M15 1L1 15M1 1L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                  </button>
                </div>

                <div class="product-sidbar-wrapper">

                  <!-- Product Type (Categories) -->
                  <div class="product-sidebar-inner-block">
                    <div class="product-sidebar-title-block">
                      <h2 class="product-sidebar-title">Product Type</h2>
                    </div>
                    <div class="product-sidebar-category-wrapper">
                      <div class="product-sidebar-category-list">
                        <div class="product-sidebar-link-wrapper">
                          <a href="/shop" class={`prodcut-sidebar-category-link w-inline-block${activeCat ? '' : ' w--current'}`}>
                            <div class="prodcut-sidebar-category-name">All Products</div>
                          </a>
                        </div>
                        {categories.map((cat) => (
                          <div class="product-sidebar-link-wrapper">
                            <a
                              href={`/shop?category=${cat.slug}`}
                              class={`prodcut-sidebar-category-link w-inline-block${activeCat?.slug === cat.slug ? ' w--current' : ''}`}
                            >
                              <div class="prodcut-sidebar-category-name">{cat.name}</div>
                            </a>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  {chips.length > 0 && (
                    <div class="product-sidebar-inner-block facet-active-block">
                      <div class="facet-active-head">
                        <span class="facet-active-count">Selected ({chips.length})</span>
                        <a href={clearUrl} class="facet-clear-link">Clear all</a>
                      </div>
                      <div class="facet-chips">
                        {chips.map((chip) => (
                          <a href={chip.removeUrl} class="facet-chip" aria-label={`Remove ${chip.label}`}>
                            <span class="facet-chip-label">{chip.label}</span>
                            <span class="facet-chip-x" aria-hidden="true">×</span>
                          </a>
                        ))}
                      </div>
                    </div>
                  )}

                  <!-- Shopify facet filters -->
                  {facets.map((facet) => (
                    <div class="product-sidebar-inner-block">
                      <div class="product-sidebar-title-block">
                        <h2 class="product-sidebar-title">{facet.label}</h2>
                      </div>

                      {facet.type === 'PRICE_RANGE' ? (
                        <div class="facet-price-row">
                          <label class="facet-price-field">
                            <span class="facet-price-label">Min</span>
                            <input type="number" name="price_min" min="0" step="1" value={priceMin ?? ''} placeholder="0" class="facet-price-input" />
                          </label>
                          <span class="facet-price-sep">–</span>
                          <label class="facet-price-field">
                            <span class="facet-price-label">Max</span>
                            <input type="number" name="price_max" min="0" step="1" value={priceMax ?? ''} placeholder="Any" class="facet-price-input" />
                          </label>
                        </div>
                      ) : (
                        <div class="facet-value-list">
                          {facet.values.filter((v) => v.count > 0 || selectedFilterInputs.includes(v.input)).map((v) => (
                            <label class="facet-value-row">
                              <input type="checkbox" name="filter" value={v.input} checked={selectedFilterInputs.includes(v.input)} class="facet-checkbox" />
                              <span class="facet-value-label">{v.label}</span>
                              <span class="facet-value-count">{v.count}</span>
                            </label>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}

                  <noscript>
                    <button type="submit" class="primary-button w-inline-block facet-apply">
                      <div class="button-text-block"><div class="button-text">Apply filters</div></div>
                      <div class="button-bg"></div>
                    </button>
                  </noscript>

                  <!-- Popular Products -->
                  <div class="product-sidebar-inner-block">
                    <div class="product-sidebar-title-block">
                      <h2 class="product-sidebar-title">Popular Products</h2>
                    </div>
                    <div class="popuplar-product-wrapper">
                      <div class="popular-product-list">
                        {popularProducts.map((product) => (
                          <div class="popular-product-item">
                            <div class="popular-product-block">
                              <a href={`/products/${product.slug}`} class="popular-product-thumbnail-block w-inline-block">
                                <img loading="lazy" src={img(product.thumbnail)} alt={product.name} class="popular-product-thumbnail" />
                              </a>
                              <div class="popular-product-info-block">
                                <a href={`/products/${product.slug}`} class="product-link-block w-inline-block">
                                  <div class="product-name">{product.name}</div>
                                </a>
                                <div class="product-card-pricing-block">
                                  <div class="product-card-sale-price">{formatMoney(product.price, product.currencyCode)}</div>
                                </div>
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  <!-- Sidebar Banner -->
                  <div class="product-sidebar-banner">
                    <img src="/images/product-sidebar-banner-image.webp" loading="lazy" alt="Banner Image" class="product-sidebar-banner-image banner-image" />
                    <div class="product-sidebar-banner-content-block">
                      <h3 class="home-banner-title custom-width-1">New Dress Collections</h3>
                      <a href="/shop/no-sidebar" class="banner-button w-inline-block">
                        <div class="button-text-block">
                          <div class="button-text">Shop Now</div>
                        </div>
                        <div class="button-bg"></div>
                      </a>
                    </div>
                  </div>

                </div>

                <!-- Drawer footer (mobile only) -->
                <div class="filter-drawer-foot">
                  <a href={clearUrl} class="filter-drawer-clear facet-clear-link">Clear all</a>
                  <button type="button" class="filter-drawer-apply" data-filter-close>
                    View {resultCount} {resultCount === 1 ? 'result' : 'results'}
                  </button>
                </div>
              </div>
            </div>

            <!-- Product Archive -->
            <div class="product-archive-wrapper">

              <!-- Sort bar -->
              <div class="product-selector-form-block w-form">
                <div class="shop-result-info">
                  <span class="selector-text">Showing {resultCount} {resultCount === 1 ? 'product' : 'products'}</span>
                </div>
                <div class="product-selector-form">
                  <div class="selector-text">Sort by:</div>
                  <select id="sortSelect" name="sort" class="product-select-input w-select">
                    {SHOP_SORT_OPTIONS.map((opt) => (
                      <option value={opt.value} selected={opt.value === sort.value}>{opt.label}</option>
                    ))}
                  </select>
                </div>
              </div>

              {products.length > 0 ? (
                <div class="product-collection-list w-dyn-list">
                  <div role="list" class="product-archive-grid-two w-dyn-items">
                    {products.map((product) => (
                      <div role="listitem" class="product-collection-item w-dyn-item reveal">
                        <div class="product-card-block">
                          <ProductCard product={product} headingTag="h3" />
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ) : (
                <div class="empty-state">
                  <p>No products match these filters.</p>
                  <a href={clearUrl} class="primary-button w-inline-block">
                    <div class="button-text-block"><div class="button-text">Clear filters</div></div>
                    <div class="button-bg"></div>
                  </a>
                </div>
              )}

              {(nextUrl || prevUrl) && (
                <div class="plp-pagination">
                  {prevUrl ? (
                    <a href={prevUrl} class="plp-page-btn" rel="prev">← Previous</a>
                  ) : (
                    <span class="plp-page-btn is-disabled" aria-disabled="true">← Previous</span>
                  )}
                  {nextUrl ? (
                    <a href={nextUrl} class="plp-page-btn" rel="next">Next →</a>
                  ) : (
                    <span class="plp-page-btn is-disabled" aria-disabled="true">Next →</span>
                  )}
                </div>
              )}
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="section-gap-bottom">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="features-wrapper" data-stagger>
            {features.map((feature) => (
              <div class="features-card-block reveal">
                <img src={`/images/${feature.icon}`} loading="lazy" alt="Features Icon" class="features-icon" />
                <div class="features-title">{feature.title}</div>
                <div class="feature-text">{feature.text}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Timer Section -->
    <section class="timer-section">
      <div class="timer-main">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="timer-inner-wrapper">
            <div class="timer-block">
              <div class="timer-subtitle">Up to 25% Off Sale</div>
              <div id="timer" class="timer-wrapper">
                <div class="timer-inner-block">
                  <div id="timer-days" class="timer-counter-text">00</div>
                  <div class="timer-counter-title">Days</div>
                </div>
                <div class="timer-counter-separator">:</div>
                <div class="timer-inner-block">
                  <div id="timer-hours" class="timer-counter-text">00</div>
                  <div class="timer-counter-title">Hours</div>
                </div>
                <div class="timer-counter-separator">:</div>
                <div class="timer-inner-block">
                  <div id="timer-minutes" class="timer-counter-text">00</div>
                  <div class="timer-counter-title">Minutes</div>
                </div>
                <div class="timer-counter-separator">:</div>
                <div class="timer-inner-block">
                  <div id="timer-seconds" class="timer-counter-text">00</div>
                  <div class="timer-counter-title">Seconds</div>
                </div>
              </div>
            </div>
            <div class="timer-separator-line"></div>
            <div class="timer-content-block">
              <h2 class="section-title text-color-white">Get Your Dress Look Today</h2>
              <p class="timer-excerpt">We checked out a bunch of stores and finally found the perfect dress!</p>
              <div class="button-wrapper center">
                <a href="/shop" class="secondary-button w-inline-block">
                  <div class="button-text-block">
                    <div class="button-text">Shop The Sale</div>
                  </div>
                  <div class="button-bg secondary"></div>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Best Sellers Section -->
    <section class="best-seller-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="best-seller-main">
            <div class="best-seller-wrapper">
              <div class="best-seller-banner-wrapper">
                <div class="best-seller-banner-content-block">
                  <div class="best-seller-subtitle">Our Best Sellers</div>
                  <h2 class="best-seller-banner-title">-20% Off for Bestsellers Product</h2>
                  <p class="best-seller-excerpt">Update your wardrobe with our most loved pieces. Simple cuts, premium fabrics, and timeless elegance.</p>
                  <a href="/shop/no-sidebar" class="primary-button w-inline-block">
                    <div class="button-text-block">
                      <div class="button-text">Shop Now</div>
                    </div>
                    <div class="button-bg"></div>
                  </a>
                </div>
                <div class="best-seller-image-block">
                  <img src="/images/best-seller-image-1.webp" loading="lazy" alt="Best Seller Banner Image" class="best-seller-bg-image home-banner-image" />
                </div>
              </div>
              <div class="best-seller-collection-list w-dyn-list">
                <div role="list" class="best-seller-collection-grid w-dyn-items">
                  {bestSellers.map((product) => (
                    <div role="listitem" class="product-collection-item w-dyn-item">
                      <div class="product-card-block">
                        <ProductCard product={product} headingTag="h3" />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* The Webflow sort bar is absolutely positioned to overlay the (now-removed)
     tab menu — anchor it as a normal header row above the product grid. */
  .product-selector-form-block {
    position: static;
    width: 100%;
    justify-content: space-between;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .facet-active-block {
    padding: 14px 16px;
  }
  .facet-active-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .facet-active-count {
    font-size: 14px;
    font-weight: 600;
    color: var(--_color---neutral-700);
  }
  .facet-clear-link {
    font-size: 14px;
    color: var(--_color---red-500);
    text-decoration: underline;
  }
  .facet-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .facet-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    border: 1px solid var(--_color---neutral-400);
    border-radius: var(--_border-radius---radius-l);
    background: var(--_color---neutral-100);
    font-size: 13px;
    line-height: 1.2;
    color: var(--_color---neutral-800);
    transition: border-color .2s ease, background-color .2s ease;
  }
  .facet-chip:hover {
    border-color: var(--_color---red-500);
    background: #fff;
  }
  .facet-chip-x {
    font-size: 16px;
    line-height: 1;
    color: var(--_color---neutral-500);
  }
  .facet-chip:hover .facet-chip-x {
    color: var(--_color---red-500);
  }
  .facet-value-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }
  .facet-value-row {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    font-size: 15px;
    color: var(--_color---neutral-700);
  }
  .facet-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--_color---red-500);
    cursor: pointer;
    flex: 0 0 auto;
  }
  .facet-value-label {
    flex: 1 1 auto;
  }
  .facet-value-count {
    color: var(--_color---neutral-500);
    font-size: 13px;
  }
  .facet-price-row {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    margin-top: 12px;
  }
  .facet-price-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 0;
  }
  .facet-price-label {
    font-size: 12px;
    color: var(--_color---neutral-500);
  }
  .facet-price-input {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid var(--_color---neutral-400);
    border-radius: var(--_border-radius---radius-xs);
    background: #fff;
    font-size: 14px;
  }
  .facet-price-sep {
    padding-bottom: 10px;
    color: var(--_color---neutral-500);
  }
  .facet-apply {
    margin-top: 8px;
  }
  .plp-pagination {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 40px;
  }
  .plp-page-btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border: 1px solid var(--_color---neutral-400);
    border-radius: var(--_border-radius---radius-xs);
    font-size: 15px;
    color: var(--_color---neutral-800);
    background: #fff;
    transition: background-color .2s ease, border-color .2s ease;
  }
  .plp-page-btn:hover {
    border-color: var(--_color---neutral-800);
  }
  .plp-page-btn.is-disabled {
    color: var(--_color---neutral-500);
    background: var(--_color---neutral-200);
    pointer-events: none;
  }
  .product-wrapper-with-sidebar.is-faceting {
    opacity: .55;
    pointer-events: none;
    transition: opacity .15s ease;
  }
</style>

<!-- AJAX faceting (filter/sort/price/pagination/category swap in place) -->
<script>
  import { initFacets } from '@/lib/facets';
  initFacets();
</script>

<script is:inline>
  /* Countdown timer */
  (function () {
    var end = new Date('2026-07-09T00:00:00').getTime();
    function tick() {
      var diff = end - Date.now();
      var pad = function (n) { return (n < 10 ? '0' : '') + n; };
      var d = diff > 0 ? Math.floor(diff / 86400000) : 0;
      var h = diff > 0 ? Math.floor(diff % 86400000 / 3600000) : 0;
      var m = diff > 0 ? Math.floor(diff % 3600000 / 60000) : 0;
      var s = diff > 0 ? Math.floor(diff % 60000 / 1000) : 0;
      ['timer-days', 'timer-hours', 'timer-minutes', 'timer-seconds'].forEach(function (id, i) {
        var el = document.getElementById(id);
        if (el) el.textContent = pad([d, h, m, s][i]);
      });
    }
    tick(); setInterval(tick, 1000);
  })();
</script>

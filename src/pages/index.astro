---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ProductCard from '@/components/sections/ProductCard.astro';
import { swatchColor } from '@/lib/colors';
import { getFeaturedProducts, getBestSellers, getSaleProducts } from '@/data/products';
import { categories } from '@/data/categories';
import { getFeaturedPosts } from '@/data/blog';
import { testimonials } from '@/data/testimonials';
import { partners } from '@/data/partners';
import { features } from '@/data/features';

const featuredProducts = getFeaturedProducts();
const bestSellers = getBestSellers();
const saleProducts = getSaleProducts().slice(0, 4);
const featuredPosts = getFeaturedPosts();

// Cart payload for the "Add Bundle to Cart" button — one line per bundle product,
// using each product's first size/color as the default variant (mirrors the PDP id format).
const bundleCartItems = saleProducts.map((p) => {
  const size = p.sizes[0] ?? '';
  const color = p.colors[0] ?? '';
  return {
    id: `${p.slug}-${size}-${color}`,
    slug: p.slug,
    name: p.name,
    price: p.price,
    image: `/images/${p.thumbnail}`,
    quantity: 1,
    size,
    color,
  };
});
---

<BaseLayout title="Dojeen - Modern Fashion E-Commerce Template" description="Discover our latest collection where fluid design meets architectural precision. Each piece is crafted to move with you.">
  <Header variant="homepage" currentPath="/" />
  <main class="main-wrapper">

    <!-- Hero Section -->
    <div id="hero-section" class="home-scroll-wrapper">
      <div class="home-scroll-wrapper-inner">
        <div id="intro" class="home-hero-main">
          <section class="home-hero-section">
            <div class="home-hero-inner-block">
              <div class="home-hero-content-main">
                <div class="home-hero-content-inner">
                  <div class="w-layout-blockcontainer container-default w-container">
                    <div class="home-hero-content-wrapper">
                      <div class="home-hero-contact-block" data-stagger>
                        <div class="home-hero-subtitle-block reveal">
                          <div class="home-hero-subtitle-line"></div>
                          <div class="home-hero-subtitle">Spring 2026</div>
                        </div>
                        <h1 class="home-hero-title reveal">Quiet Luxury! Timeless Form.</h1>
                        <p class="home-hero-excerpt reveal">Discover our latest collection where fluid design meets architectural precision. Each piece is crafted to move with you.</p>
                        <div class="home-hero-funfact-wrapper reveal">
                          <div class="home-hero-fun-fact-block">
                            <div class="home-hero-fun-fact-text">40</div>
                            <div class="home-hero-fun-fact-title">New Pieces</div>
                          </div>
                          <div class="home-hero-fun-fact-block">
                            <div class="home-hero-fun-fact-text">100%</div>
                            <div class="home-hero-fun-fact-title">Sustainable</div>
                          </div>
                        </div>
                        <div class="button-wrapper center reveal">
                          <a href="/shop" class="primary-button w-inline-block">
                            <div class="button-text-block">
                              <div class="button-text">Shop Now</div>
                            </div>
                            <div class="button-bg"></div>
                          </a>
                          <a href="/shop/no-sidebar" class="secondary-button w-inline-block">
                            <div class="button-text-block">
                              <div class="button-text">View More</div>
                            </div>
                            <div class="button-bg secondary"></div>
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="home-hero-marquee" aria-hidden="true">
                  <div class="home-hero-marquee-inner">
                    <div class="home-hero-marquee-text">ESSENTIALS</div>
                    <div class="home-hero-marquee-text">ESSENTIALS</div>
                    <div class="home-hero-marquee-text">ESSENTIALS</div>
                  </div>
                  <div class="home-hero-marquee-inner">
                    <div class="home-hero-marquee-text">ESSENTIALS</div>
                    <div class="home-hero-marquee-text">ESSENTIALS</div>
                    <div class="home-hero-marquee-text">ESSENTIALS</div>
                  </div>
                </div>
              </div>
              <div class="home-hero-image-block">
                <img src="/images/home-hero-image-new-2.jpg" loading="eager" fetchpriority="high" decoding="async" alt="Home Hero Image" class="home-hero-image" />
              </div>
            </div>
          </section>
        </div>
        <div class="home-overlay"></div>

        <!-- About Section -->
        <section id="about" class="home-about-section">
          <div class="w-layout-blockcontainer container-fluid w-container">
            <div class="home-about-wrapper">
              <div class="home-about-content-block">
                <div class="home-about-eyebrow">
                  <span class="home-about-eyebrow-line"></span>
                  <span class="home-about-eyebrow-text">The Dojeen Ethos</span>
                  <span class="home-about-eyebrow-line"></span>
                </div>
                <h2 class="home-about-title">Quiet Luxury, Crafted to Move With You</h2>
                <p class="home-about-excerpt">Considered cuts, premium fabrics, and a timeless palette — pieces designed to live in, season after season.</p>
                <div class="button-wrapper center">
                  <a href="/about" class="primary-button w-inline-block">
                    <div class="button-text-block">
                      <div class="button-text">More About Us</div>
                    </div>
                    <div class="button-bg"></div>
                  </a>
                </div>
              </div>
              <div class="home-about-image-wrapper">
                <img src="/images/home-about-image-1.webp" loading="lazy" alt="About Image" class="about-image one" />
                <img src="/images/home-about-image-2.webp" loading="lazy" alt="About Image" class="about-image two" />
                <img src="/images/home-about-image-4.webp" loading="lazy" alt="About Image" class="about-image three" />
                <img src="/images/home-about-image-3.webp" loading="lazy" alt="About Image" class="about-image four" />
                <img src="/images/home-about-image-5.webp" loading="lazy" alt="About Image" class="about-image five" />
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>

    <!-- Categories Section -->
    <section class="product-category-section">
      <div class="section-gap-bottom">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="section-title-block center">
            <div class="section-subtitle reveal">Fashion's Gallery</div>
            <div class="section-title-inner category">
              <h2 class="section-title reveal">Explore Our Collections</h2>
            </div>
          </div>
          <div class="product-category-wrapper">
            <div class="category-collection-list-wrapper w-dyn-list">
              <div role="list" class="category-collection-list w-dyn-items">
                {categories.slice(0, 5).map((cat) => (
                  <div role="listitem" class="category-collection-list-item w-dyn-item">
                    <a href={`/shop/category/${cat.slug}`} class="category-card-block w-inline-block">
                      <div class="category-card-title-block">
                        <div class="category-serial-number">{cat.serialNumber}</div>
                        <h3 class="product-collection-name">{cat.name}</h3>
                      </div>
                      <div class="category-thumbnail-block">
                        <img loading="lazy" src={`/images/${cat.thumbnail}`} alt={`${cat.name} Thumbnail`} class="category-thumbnail" />
                      </div>
                      <div class="category-card-content-block">
                        <div class="product-amount-text">{cat.productCount} Items</div>
                        <div aria-label="Category Link" class="category-arrow">
                          <div class="link-icon two w-embed">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="14" viewBox="0 0 20 14" fill="none">
                              <path d="M18.9936 6.37062L12.8686 0.245623C12.7036 0.0862349 12.4826 -0.00196054 12.2531 3.30772e-05C12.0237 0.00202669 11.8043 0.0940497 11.642 0.256282C11.4798 0.418514 11.3878 0.637975 11.3858 0.867397C11.3838 1.09682 11.472 1.31785 11.6314 1.48287L16.2628 6.11425H0.875C0.642936 6.11425 0.420376 6.20644 0.256282 6.37053C0.0921872 6.53462 0 6.75718 0 6.98925C0 7.22131 0.0921872 7.44387 0.256282 7.60797C0.420376 7.77206 0.642936 7.86425 0.875 7.86425H16.2628L11.6314 12.4956C11.5478 12.5763 11.4811 12.6729 11.4353 12.7796C11.3894 12.8864 11.3653 13.0012 11.3643 13.1174C11.3633 13.2336 11.3854 13.3488 11.4294 13.4563C11.4734 13.5639 11.5384 13.6616 11.6205 13.7437C11.7027 13.8259 11.8004 13.8908 11.9079 13.9348C12.0154 13.9788 12.1307 14.001 12.2469 14C12.363 13.999 12.4778 13.9748 12.5846 13.929C12.6914 13.8831 12.7879 13.8164 12.8686 13.7329L18.9936 7.60787C19.1577 7.44379 19.2498 7.22127 19.2498 6.98925C19.2498 6.75723 19.1577 6.53471 18.9936 6.37062Z" fill="currentColor" />
                            </svg>
                          </div>
                          <div class="link-icon one w-embed">
                            <svg xmlns="http://www.w3.org/2000/svg" width="9" height="14" viewBox="0 0 9 14" fill="none">
                              <path d="M8.98484 6.99753C8.98484 7.24835 8.87698 7.49914 8.66171 7.69037L1.8843 13.708C1.45317 14.0908 0.754169 14.0908 0.323215 13.708C-0.107738 13.3254 -0.107738 12.7048 0.323215 12.322L6.32025 6.99753L0.323425 1.673C-0.107529 1.2902 -0.107529 0.669744 0.323425 0.287128C0.754378 -0.0958586 1.45338 -0.0958586 1.88451 0.287128L8.66192 6.30468C8.87723 6.496 8.98484 6.7468 8.98484 6.99753Z" fill="currentColor" />
                            </svg>
                          </div>
                        </div>
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Offers Section -->
    <section class="offers-section">
      <div class="offers-wrapper">
        <div class="offers-content-main">
          <div class="offers-content-wrapper">
            <div class="offers-content-inner">
              <div class="w-layout-blockcontainer container-default w-container">
                <div class="offers-content-block">
                  <div class="offers-content-inner-block">
                    <div class="section-subtitle reveal">Biggest Sale Offer</div>
                    <div class="section-title-inner offers">
                      <h2 class="section-title reveal">New &amp; Modern Products in Our Online Store</h2>
                    </div>
                    <div class="offers-button-wrapper reveal">
                      <a href="/shop" class="primary-button w-inline-block">
                        <div class="button-text-block">
                          <div class="button-text">Shop Now</div>
                        </div>
                        <div class="button-bg"></div>
                      </a>
                    </div>
                  </div>
                  <div class="offers-text-block reveal">
                    <div class="offers-text">Midseason Sale <span class="offers-text-span">25%</span> Off!</div>
                    <div class="offers-text-separation"></div>
                    <div class="offers-text">Only <a href="/shop/no-sidebar" class="offers-link">Selected Product</a></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="offers-slider-wrapper">
          <div class="offers-slider w-slider" id="offersSlider">
            <div class="offer-slider-mask w-slider-mask">
              {(() => {
                const offerBgs = [
                  { prevBg: 'offers-slider-image-4.webp', activeBg: 'offers-slider-image-1.webp' },
                  { prevBg: 'offers-slider-image-1.webp', activeBg: 'offers-slider-image-2.webp' },
                  { prevBg: 'offers-slider-image-2.webp', activeBg: 'offers-slider-image-3.webp' },
                  { prevBg: 'offers-slider-image-3.webp', activeBg: 'offers-slider-image-4.webp' },
                ];
                return saleProducts.map((product, idx) => {
                  const bg = offerBgs[idx % offerBgs.length];
                  return (
                    <div class={`offer-slider-item w-slide${idx === 0 ? ' is-active' : ''}`}>
                      <div class="offer-slider-card-block">
                        <img src={`/images/${bg.prevBg}`} loading="lazy" alt="Offer BG Image" class="offers-bg-image-previous" />
                        <img src={`/images/${bg.activeBg}`} loading="lazy" alt="Offer BG Image" class="offers-bg-image-active" />
                        <div class="offers-collection-list w-dyn-list">
                          <div role="list" class="offers-collections w-dyn-items">
                            <div role="listitem" class="offers-collection w-dyn-item">
                              <div class="offerse-card-block">
                                <ProductCard product={product} headingTag="h3" />
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  );
                });
              })()}
            </div>
            <div class="hidden-slider-arrow w-slider-arrow-left" id="offersPrev">
              <div class="w-icon-slider-left"></div>
            </div>
            <div class="hidden-slider-arrow w-slider-arrow-right" id="offersNext">
              <div class="w-icon-slider-right"></div>
            </div>
            <div class="offers-slider-nav w-slider-nav w-shadow w-round" id="offersNav"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Products Section -->
    <section class="product-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="section-title-block center">
            <div class="section-subtitle reveal">New Arrivals</div>
            <div class="section-title-inner product">
              <h2 class="section-title reveal">Modern &amp; Trendy Styles Just Arrived</h2>
            </div>
          </div>
          <div class="product-slider w-slider" id="productSlider">
            <div class="left-overlay"></div>
            <div class="right-overlay"></div>
            <div class="product-slider-mask w-slider-mask">
              {featuredProducts.slice(0, 5).map((product) => (
                <div class="product-slider-item w-slide">
                  <div class="product-collection-list w-dyn-list">
                    <div role="list" class="product-slider-item-wrapper w-dyn-items">
                      <div role="listitem" class="product-collection-item w-dyn-item">
                        <div class="product-card-block">
                          <ProductCard product={product} headingTag="h3" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="product-slider-arrow left w-slider-arrow-left" id="productPrev">
              <div class="product-slider-arrow-icon w-icon-slider-left"></div>
            </div>
            <div class="product-slider-arrow right w-slider-arrow-right" id="productNext">
              <div class="product-slider-arrow-icon w-icon-slider-right"></div>
            </div>
            <div class="hidden-slider-nav w-slider-nav w-round w-num"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Badge Marquee Section -->
    <section class="badge-section" aria-hidden="true">
      <div class="badge-marquee-wrapper">
        {[1, 2].map(() => (
          <div class="badge-marquee-inner">
            <div class="badge-marquee-block">
              <img src="/images/badge-icon-1.svg" loading="lazy" alt="Badge Icon" class="badge-icon" />
              <div class="badge-text">New Arrivals Every Week</div>
            </div>
            <div class="badge-marquee-block">
              <img src="/images/badge-icon-2.svg" loading="lazy" alt="Badge Icon" class="badge-icon" />
              <div class="badge-text">Limited Edition Styles</div>
            </div>
            <div class="badge-marquee-block">
              <img src="/images/badge-icon-3.svg" loading="lazy" alt="Badge Icon" class="badge-icon" />
              <div class="badge-text">Shop the Latest Trends</div>
            </div>
            <div class="badge-marquee-block">
              <img src="/images/badge-icon-4.svg" loading="lazy" alt="Badge Icon" class="badge-icon" />
              <div class="badge-text">Cute. Comfy. Confident.</div>
            </div>
            <div class="badge-marquee-block">
              <img src="/images/badge-icon-5.svg" loading="lazy" alt="Badge Icon" class="badge-icon" />
              <div class="badge-text">Fashion Made to Feel Good</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Banners Section -->
    <section class="home-banner-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="banner-wrapper">
            <div class="home-banner reveal">
              <div class="home-banner-content-block">
                <div class="banner-subtitle">New Collection</div>
                <h2 class="home-banner-title-two">Elegant Design Dress</h2>
                <a aria-label="Banner Link" href="/shop/no-sidebar" class="banner-circle-button w-inline-block">
                  <div class="link-icon w-embed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
                      <path d="M14.0334 0H2.69849C2.16528 0 1.73169 0.433594 1.73169 0.966797C1.73169 1.5 2.16528 1.93359 2.69849 1.93359H11.6956L0.284424 13.3477C-0.0935059 13.7256 -0.0935059 14.3379 0.284424 14.7158C0.662353 15.0938 1.27466 15.0938 1.65259 14.7158L13.0637 3.30176V12.2988C13.0637 12.832 13.4973 13.2656 14.0305 13.2656C14.5637 13.2656 14.9973 12.832 14.9973 12.2988V0.966797C15.0002 0.433594 14.5667 0 14.0334 0Z" fill="currentColor" />
                    </svg>
                  </div>
                </a>
              </div>
              <div class="home-banner-image-block">
                <img src="/images/banner-image-3.webp" loading="lazy" alt="Banner Image" class="home-banner-image" />
              </div>
            </div>
            <div class="home-banner reveal">
              <div class="home-banner-content-block">
                <div class="banner-subtitle">Up to 30% Off</div>
                <h2 class="home-banner-title-two">Modern Design Dress</h2>
                <a aria-label="Banner Link" href="/shop/no-sidebar" class="banner-circle-button w-inline-block">
                  <div class="link-icon w-embed">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
                      <path d="M14.0334 0H2.69849C2.16528 0 1.73169 0.433594 1.73169 0.966797C1.73169 1.5 2.16528 1.93359 2.69849 1.93359H11.6956L0.284424 13.3477C-0.0935059 13.7256 -0.0935059 14.3379 0.284424 14.7158C0.662353 15.0938 1.27466 15.0938 1.65259 14.7158L13.0637 3.30176V12.2988C13.0637 12.832 13.4973 13.2656 14.0305 13.2656C14.5637 13.2656 14.9973 12.832 14.9973 12.2988V0.966797C15.0002 0.433594 14.5667 0 14.0334 0Z" fill="currentColor" />
                    </svg>
                  </div>
                </a>
              </div>
              <div class="home-banner-image-block">
                <img src="/images/banner-image-2.webp" loading="lazy" alt="Banner Image" class="home-banner-image" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="home-cta-section">
      <div class="home-cta-wrapper">
        <div class="home-cta-content-block">
          <div class="cta-content-inner">
            <div class="cta-section-title-block">
              <div class="section-subtitle text-color-white reveal">Up to 25% Off Sale</div>
              <h2 class="section-title text-color-white reveal">Best Fashion Store Available to Everyone!</h2>
            </div>
            <a href="/shop/no-sidebar" class="text-link reveal">Shop Collection</a>
          </div>
        </div>
        <div class="cta-video-wrapper">
          <div class="cta-video w-background-video w-background-video-atom">
            <video id="cta-video-el" autoplay loop muted playsinline style="background-image:url('/videos/home-video-poster-00001.jpg')">
              <source src="/videos/home-video-transcode.mp4" type="video/mp4" />
              <source src="/videos/home-video-transcode.webm" type="video/webm" />
            </video>
            <div class="video-button-block">
              <div aria-live="polite">
                <button type="button" id="ctaVideoToggle" class="play-pause-button w-background-video--control" aria-label="Pause video">
                  <span class="play-state-2">
                    <img src="/images/Pause-video.svg" loading="lazy" alt="Pause video" class="pause-icon" />
                  </span>
                  <span hidden class="pause-state-2">
                    <img loading="lazy" alt="Play video" src="/images/Play-video.svg" class="play-icon" />
                  </span>
                </button>
              </div>
            </div>
            <div class="cta-video-overlay"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bundle Section -->
    <section class="bundle-product-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="section-title-block center">
            <div class="section-subtitle reveal">Bundle &amp; Save</div>
            <div class="section-title-inner bundle">
              <h2 class="section-title reveal">Build Your Product Bundle &amp; Save Money</h2>
            </div>
          </div>
          <div class="bundle-offer-scroll-wrap">
            <div class="bundle-offer-grid">
              <div class="bundle-offer-product-wrapper">
                <div class="bundle-offer-product-inner">
                  <div>
                    <div class="bundle-product-collection-list w-dyn-list">
                      <div role="list" class="bundle-product-wrapper w-dyn-items">
                        {saleProducts.map((product) => {
                          const bundleImg3 = product.images[0] ?? product.thumbnail;
                          return (
                          <div role="listitem" class="product-collection-item w-dyn-item">
                            <div class="bundle-product-card-block">
                              <div class="product-tab-wrapper">
                                <div class="prouct-card-tab w-tabs">
                                  <div class="product-tab-content w-tab-content">
                                    <div class="product-tab-pane w-tab-pane w--tab-active" data-tab="1">
                                      <a href={`/products/${product.slug}`} class="product-thumbnail-block w-inline-block">
                                        <img loading="lazy" src={`/images/${product.thumbnail}`} alt={product.name} class="bundle-product-main-thumbnail" />
                                        <img loading="lazy" src={`/images/${product.thumbnailHover}`} alt={product.name} class="bundle-product-secondary-thumbnail" />
                                      </a>
                                    </div>
                                    <div class="product-tab-pane w-tab-pane" data-tab="2">
                                      <a href={`/products/${product.slug}`} class="product-thumbnail-block w-inline-block">
                                        <img loading="lazy" src={`/images/${product.thumbnailHover}`} alt={product.name} class="bundle-product-main-thumbnail" />
                                      </a>
                                    </div>
                                    <div class="product-tab-pane w-tab-pane" data-tab="3">
                                      <a href={`/products/${product.slug}`} class="product-thumbnail-block w-inline-block">
                                        <img loading="lazy" src={`/images/${bundleImg3}`} alt={product.name} class="bundle-product-main-thumbnail" />
                                      </a>
                                    </div>
                                  </div>
                                  <div class="bundle-product-tab-menu w-tab-menu">
                                    {product.colors.slice(0, 3).map((color, i) => (
                                      <a class={`product-tab-link w-inline-block w-tab-link${i === 0 ? ' w--current' : ''}`} data-target={String(i + 1)}>
                                        <div class="product-tab-block" style={`background-color:${swatchColor(color)}`}></div>
                                      </a>
                                    ))}
                                  </div>
                                </div>
                              </div>
                              <div class="product-card-info-block">

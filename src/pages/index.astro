    /* images hidden pre-JS; the scroll script drives their corner-assemble entrance */
    .home-about-section .about-image {
      opacity: 0;
    }
  }
</style>

<script is:inline>
  /* Honor the user's reduced-motion preference across all homepage motion. */
  var REDUCE_MOTION = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* Pause the CSS-keyframe badge marquee while hovered. */
  (function () {
    var el = document.querySelector('.badge-marquee-wrapper');
    if (!el) return;
    el.addEventListener('mouseenter', function () { el.classList.add('is-paused'); });
    el.addEventListener('mouseleave', function () { el.classList.remove('is-paused'); });
  })();

  /* ── Countdown Timer ── */
  (function () {
    var end = new Date('2026-07-09T00:00:00').getTime();
    var prev = {};
    function tick() {
      var diff = end - Date.now();
      var pad = function(n) { return (n < 10 ? '0' : '') + n; };
      var d = diff > 0 ? Math.floor(diff / 86400000) : 0;
      var h = diff > 0 ? Math.floor(diff % 86400000 / 3600000) : 0;
      var m = diff > 0 ? Math.floor(diff % 3600000 / 60000) : 0;
      var s = diff > 0 ? Math.floor(diff % 60000 / 1000) : 0;
      ['timer-days','timer-hours','timer-minutes','timer-seconds'].forEach(function(id, i) {
        var el = document.getElementById(id);
        if (!el) return;
        var val = pad([d,h,m,s][i]);
        if (prev[id] === val) return;
        prev[id] = val;
        el.textContent = val;
        /* tiny tick animation on change (skipped when reduced) */
        if (!REDUCE_MOTION) {
          el.classList.remove('is-ticking');
          void el.offsetWidth; /* reflow to restart animation */
          el.classList.add('is-ticking');
        }
      });
    }
    tick(); setInterval(tick, 1000);
  })();

  /* ── Transform-based slider factory ──
     Positions .w-slide elements side-by-side via inline-block + white-space:nowrap
     (set by global.css .w-slider-mask), then translates the mask to navigate. */
  function makeSlider(sliderId, prevId, nextId, navId, autoplayMs) {
    var slider = document.getElementById(sliderId);
    if (!slider) return;
    var mask = slider.querySelector('.w-slider-mask');
    if (!mask) return;
    var slides = Array.from(mask.querySelectorAll('.w-slide'));
    if (!slides.length) return;

    var nav = navId ? document.getElementById(navId) : null;
    var total = slides.length;
    var cur = 0;

    mask.style.transition = 'transform 0.45s ease';

    /* Build nav dots */
    function buildNav() {
      if (!nav) return;
      nav.innerHTML = '';
      slides.forEach(function(_, i) {
        var dot = document.createElement('div');
        dot.className = 'w-slider-dot' + (i === 0 ? ' w-active' : '');
        dot.addEventListener('click', function() { go(i); });
        nav.appendChild(dot);
      });
    }

    function updateNav() {
      if (!nav) return;
      nav.querySelectorAll('.w-slider-dot').forEach(function(d, i) {
        d.classList.toggle('w-active', i === cur);
      });
    }

    /* Each slide spans (mask.offsetWidth + 30px) horizontally (mask width + two 15px margins).
       Translate by that many pixels per step so slides align exactly with the mask left edge.
       Clamp to maxPos so we never show empty space beyond the last slide. */
    function getSlideSpan() { return mask.offsetWidth + 30; }
    function getMaxPos() { return Math.max(0, total - Math.max(1, Math.round(slider.offsetWidth / getSlideSpan()))); }

    function applyTransform() {
      mask.style.transform = 'translate3d(-' + (cur * getSlideSpan()) + 'px, 0, 0)';
    }

    function go(idx) {
      cur = Math.max(0, Math.min(getMaxPos(), idx));
      applyTransform();
      updateNav();
    }

    buildNav();

    var prev = prevId ? document.getElementById(prevId) : null;
    var next = nextId ? document.getElementById(nextId) : null;
    if (prev) prev.addEventListener('click', function() { go(cur - 1); });
    if (next) next.addEventListener('click', function() { go(cur + 1); });
    if (autoplayMs) setInterval(function() { go(cur + 1); }, autoplayMs);

    window.addEventListener('resize', function() {
      var max = getMaxPos();
      if (cur > max) cur = max;
      applyTransform();
    });
  }

  /* Offers slider: fade model (all slides stacked, toggle opacity + is-active class).
     Webflow uses IX2 for this effect; translate-based sliding would sweep slides through
     the left column, so we use opacity instead. */
  (function () {
    var slider = document.getElementById('offersSlider');
    if (!slider) return;
    var mask = slider.querySelector('.offer-slider-mask');
    if (!mask) return;
    var slides = Array.from(mask.querySelectorAll('.w-slide'));
    if (!slides.length) return;
    var nav = document.getElementById('offersNav');
    var total = slides.length;
    var cur = 0;

    function buildNav() {
      if (!nav) return;
      nav.innerHTML = '';
      slides.forEach(function(_, i) {
        var dot = document.createElement('div');
        dot.className = 'w-slider-dot' + (i === 0 ? ' w-active' : '');
        dot.addEventListener('click', function() { go(i); });
        nav.appendChild(dot);
      });
    }

    function go(idx) {
      var next = ((idx % total) + total) % total;
      slides[cur].classList.remove('is-active');
      cur = next;
      slides[cur].classList.add('is-active');
      if (nav) nav.querySelectorAll('.w-slider-dot').forEach(function(d, i) {
        d.classList.toggle('w-active', i === cur);
      });
    }

    buildNav();
    var prev = document.getElementById('offersPrev');
    var next = document.getElementById('offersNext');
    if (prev) prev.addEventListener('click', function() { go(cur - 1); });
    if (next) next.addEventListener('click', function() { go(cur + 1); });

    /* Autoplay with pause-on-hover (skipped entirely under reduced-motion) */
    var timer = null;
    function start() { if (!REDUCE_MOTION && !timer) timer = setInterval(function() { go(cur + 1); }, 5000); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    start();
  })();

  makeSlider('productSlider', 'productPrev', 'productNext', null, null);

  /* Partner slider: crossfade (Webflow data-animation="cross") */
  (function () {
    var slider = document.getElementById('partnerSlider');
    if (!slider) return;
    var slides = Array.from(slider.querySelectorAll('.partner-slider-mask .w-slide'));
    if (!slides.length) return;
    var cur = 0;
    var total = slides.length;

    function go(idx) {
      var next = ((idx % total) + total) % total;
      slides[cur].classList.remove('is-active');
      cur = next;
      slides[cur].classList.add('is-active');
    }

    var prev = document.getElementById('partnerPrev');
    var next = document.getElementById('partnerNext');
    if (prev) prev.addEventListener('click', function () { go(cur - 1); });
    if (next) next.addEventListener('click', function () { go(cur + 1); });

    /* Autoplay with pause-on-hover (skipped entirely under reduced-motion) */
    var timer = null;
    function start() { if (!REDUCE_MOTION && !timer) timer = setInterval(function () { go(cur + 1); }, 4000); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    start();
  })();

  /* ── CTA video play/pause ── */
  (function () {
    var btn = document.getElementById('ctaVideoToggle');
    var vid = document.getElementById('cta-video-el');
    if (!btn || !vid) return;
    btn.addEventListener('click', function () {
      if (vid.paused) {
        vid.play();
        btn.querySelector('.play-state-2').removeAttribute('hidden');
        btn.querySelector('.pause-state-2').setAttribute('hidden', '');
        btn.setAttribute('aria-label', 'Pause video');
      } else {
        vid.pause();
        btn.querySelector('.play-state-2').setAttribute('hidden', '');
        btn.querySelector('.pause-state-2').removeAttribute('hidden');
        btn.setAttribute('aria-label', 'Play video');
      }
    });
  })();

  /* ── CTA section: scroll-driven video expansion ── */
  (function () {
    var section = document.querySelector('.home-cta-section');
    var videoWrapper = section ? section.querySelector('.cta-video-wrapper') : null;
    var contentBlock = section ? section.querySelector('.home-cta-content-block') : null;
    if (!section || !videoWrapper) return;

    function clearInline() {
      videoWrapper.style.width = '';
      videoWrapper.style.height = '';
      videoWrapper.style.borderRadius = '';
      videoWrapper.style.transform = '';
      if (contentBlock) contentBlock.style.opacity = '';
    }

    /* Reduced motion: show the video at its static frame, no scroll expansion. */
    if (REDUCE_MOTION) { clearInline(); return; }

    function update() {
      if (window.innerWidth <= 991) { clearInline(); return; }

      var rect = section.getBoundingClientRect();
      var extra = section.offsetHeight - window.innerHeight; /* 100vh of extra scroll */
      if (extra <= 0) { clearInline(); return; }

      var progress = Math.min(1, Math.max(0, -rect.top / extra));

      var startSize = 0.07 * window.innerWidth; /* 7vw in px */
      var parent = videoWrapper.parentElement;
      var endW = parent.offsetWidth;
      var endH = parent.offsetHeight;

      videoWrapper.style.width        = (startSize + (endW - startSize) * progress) + 'px';
      videoWrapper.style.height       = (startSize + (endH - startSize) * progress) + 'px';
      videoWrapper.style.borderRadius = (1000 * (1 - progress)) + 'px';
      videoWrapper.style.transform    = 'translate(0, ' + (10 * (1 - progress)) + 'vh)';

      /* fade out text content as video fills the frame */
      if (contentBlock) {
        var fadeProgress = Math.max(0, (progress - 0.3) / 0.7);
        contentBlock.style.opacity = String(Math.max(0, 1 - fadeProgress));
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  })();

  /* ── Testimonial section: scroll-driven horizontal slide ── */
  /* Ports the Webflow GSAP logic exactly:
     - testimonialMain.top = (vh - mainHeight) / 2  (vertical centering)
     - marqueeInner starts at shiftX  (first card centered in viewport)
     - marqueeInner ends   at endX    (last card centered in viewport)
     - Active card (closest to viewport centre) → scale 1 / opacity 1; rest → 0.9 / 0.7
     - Lerp factor 0.12 ≈ GSAP scrub:0.6 smoothing
     - Runs at ≥768px; resets to static layout below that */
  (function () {
    var scrollWrap      = document.querySelector('.testimonial-scroll-wrapper');
    var testimonialMain = document.querySelector('.testimonial-main');
    var marqueeInner    = document.querySelector('.testimonial-marquee-inner');
    var cards = Array.from(document.querySelectorAll('.testimonial-section .testimonial-card-block'));
    if (!scrollWrap || !testimonialMain || !marqueeInner || !cards.length) return;

    var state   = { shiftX: 0, endX: 0, scrollStart: 0, travelDistance: 1 };
    var lerpX   = 0;
    var targetX = 0;
    var enabled = false;
    var ticking = false;

    /* ── Mobile touch slider ── */
    var mobileCards = [];
    var mobileIdx   = 0;
    var mobileDotsEl = null;
    var touchStartX = 0, touchStartY = 0;
    var mlStart = null, mlEnd = null;

    function goToMobileSlide(idx) {
      mobileIdx = Math.max(0, Math.min(idx, mobileCards.length - 1));
      var card = mobileCards[mobileIdx];
      if (!card) return;
      marqueeInner.style.transform = 'translateX(' + (-card.offsetLeft) + 'px)';
      if (mobileDotsEl) {
        Array.from(mobileDotsEl.children).forEach(function (d, i) {
          d.classList.toggle('active', i === mobileIdx);
        });
      }
    }

    function setupMobileSlider() {
      var blocks = document.querySelectorAll('.testimonial-section .testimonial-marquee-block');
      mobileCards = blocks[0] ? Array.from(blocks[0].querySelectorAll('.testimonial-card-block')) : [];
      mobileIdx = 0;

      mobileCards.forEach(function (card) {
        card.style.transform  = '';
        card.style.opacity    = '1';
        card.style.transition = '';
      });
      marqueeInner.style.transform = 'translateX(0)';

      /* dots */
      if (!mobileDotsEl) {
        mobileDotsEl = document.createElement('div');
        mobileDotsEl.className = 'testimonial-mobile-dots';
        mobileCards.forEach(function (_, i) {
          var dot = document.createElement('button');
          dot.className = 'testimonial-mobile-dot' + (i === 0 ? ' active' : '');
          dot.setAttribute('aria-label', 'Slide ' + (i + 1));
          (function (idx) { dot.addEventListener('click', function () { goToMobileSlide(idx); }); })(i);
          mobileDotsEl.appendChild(dot);
        });
        testimonialMain.appendChild(mobileDotsEl);
      }

      /* touch events */
      if (mlStart) { marqueeInner.removeEventListener('touchstart', mlStart); marqueeInner.removeEventListener('touchend', mlEnd); }
      mlStart = function (e) { touchStartX = e.touches[0].clientX; touchStartY = e.touches[0].clientY; };
      mlEnd   = function (e) {
        var dx = e.changedTouches[0].clientX - touchStartX;
        var dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
          goToMobileSlide(dx < 0 ? mobileIdx + 1 : mobileIdx - 1);
        }
      };
      marqueeInner.addEventListener('touchstart', mlStart, { passive: true });
      marqueeInner.addEventListener('touchend',   mlEnd,   { passive: true });

      goToMobileSlide(0);
    }

    function teardownMobileSlider() {
      if (mlStart) { marqueeInner.removeEventListener('touchstart', mlStart); marqueeInner.removeEventListener('touchend', mlEnd); mlStart = mlEnd = null; }
      cards.forEach(function (card) { card.style.width = ''; card.style.maxWidth = ''; card.style.flexShrink = ''; card.style.marginRight = ''; });
      marqueeInner.style.transition = '';
    }

    function absTop(el) {
      var t = 0; while (el) { t += el.offsetTop; el = el.offsetParent; } return t;
    }

    function recalc() {
      /* reset so we measure natural card positions */
      marqueeInner.style.transition = 'none';
      marqueeInner.style.transform  = 'translateX(0)';

      var vh    = window.innerHeight;
      var mainH = testimonialMain.offsetHeight;
      testimonialMain.style.top = Math.round((vh - mainH) / 2) + 'px';

      /* shiftX: first card centred in viewport */
      var fcRect = cards[0].getBoundingClientRect();
      state.shiftX = window.innerWidth / 2 - (fcRect.left + fcRect.width / 2);

      /* endX: last card centred in viewport */
      var totalWidth = Math.max(0, marqueeInner.scrollWidth - window.innerWidth);
      var lastCard   = cards[cards.length - 1];
      state.endX     = -(totalWidth + (window.innerWidth / 2 - lastCard.offsetWidth / 2));

      /* scroll window: mirrors GSAP start/end formula */
      var topOffset        = (vh - mainH) / 2 - 50;
      state.scrollStart    = absTop(scrollWrap) + topOffset;
      state.travelDistance = Math.max(1, totalWidth - window.innerWidth * 0.2);

      cards.forEach(function (card) {
        card.style.transition = 'transform 0.6s ease, opacity 0.6s ease';
        card.style.transform  = 'scale(0.9)';
        card.style.opacity    = '0.7';
      });

      lerpX   = state.shiftX;
      targetX = state.shiftX;
      marqueeInner.style.transform = 'translateX(' + lerpX + 'px)';
      updateActiveCard();
    }

    function updateActiveCard() {
      var centre = window.innerWidth / 2;
      var best = null, bestDist = Infinity;
      cards.forEach(function (card) {
        var rect = card.getBoundingClientRect();
        var dist = Math.abs(centre - (rect.left + rect.width / 2));
        if (dist < bestDist) { bestDist = dist; best = card; }
      });
      cards.forEach(function (card) {
        var on = card === best;
        card.style.transform = on ? 'scale(1)' : 'scale(0.9)';
        card.style.opacity   = on ? '1' : '0.7';
      });
    }

    function computeTarget() {
      var scrollY  = window.scrollY || window.pageYOffset;
      var progress = Math.max(0, Math.min(1, (scrollY - state.scrollStart) / state.travelDistance));
      targetX = state.shiftX + (state.endX - state.shiftX) * progress;
    }

    function tick() {
      if (!ticking) return;
      if (Math.abs(targetX - lerpX) > 0.1) {
        lerpX += (targetX - lerpX) * 0.12;
        marqueeInner.style.transform = 'translateX(' + lerpX + 'px)';
        updateActiveCard();
      }
      requestAnimationFrame(tick);
    }

    function setup() {
      ticking = false;
      enabled = false;

      /* Reduced motion or mobile: use the static, swipeable slider — no scroll-jacking. */
      if (REDUCE_MOTION || window.innerWidth < 768) {
        testimonialMain.style.top = '';
        teardownMobileSlider();
        setupMobileSlider();
        return;
      }

      /* returning from mobile → restore desktop layout */
      teardownMobileSlider();
      recalc();
      computeTarget();
      enabled = true;
      ticking = true;
      requestAnimationFrame(tick);
    }

    window.addEventListener('scroll', function () {
      if (!enabled) return;
      computeTarget();
    }, { passive: true });

    window.addEventListener('resize', setup);

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }
  })();

  /* ── Bundle section: sync page scroll to inner product list scroll ── */
  /* Mirrors the GSAP ScrollTrigger logic from dojeen.webflow/index.html lines 1997-2071 */
  (function () {
    var wrap  = document.querySelector('.bundle-offer-scroll-wrap');
    var inner = document.querySelector('.bundle-offer-product-wrapper');
    if (!wrap || !inner) return;

    /* Reduced motion: don't pin/sync — let the inner list scroll on its own. */
    if (REDUCE_MOTION) { inner.scrollTop = 0; return; }

    function update() {
      if (window.innerWidth < 992) { inner.scrollTop = 0; return; }
      var rect       = wrap.getBoundingClientRect();
      var stickyTop  = 100; /* matches bundle-offer-grid { top: 100px } */
      /* How far page has scrolled past the pin point */
      var scrolled   = Math.max(0, stickyTop - rect.top);
      /* Total page distance available while the grid is pinned */
      var available  = wrap.offsetHeight - (window.innerHeight - stickyTop);
      if (available <= 0) return;
      var progress   = Math.min(1, scrolled / available);
      var maxInner   = Math.max(0, inner.scrollHeight - inner.clientHeight);
      inner.scrollTop = progress * maxInner;
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  })();

  /* ── Home: sticky scroll — overlay fades in over hero, about content fades in on top ── */
  /* Replicates Webflow IX2 scrub on .home-scroll-wrapper (350vh) + .home-scroll-wrapper-inner (sticky) */
  /* Desktop only (>991px); on ≤991px the wrapper is height:auto and sticky is position:static */
  (function () {
    var wrapper = document.querySelector('.home-scroll-wrapper');
    var overlay = document.querySelector('.home-overlay');
    var about   = document.getElementById('about');
    if (!wrapper || !overlay || !about) return;

    var els = [
      about.querySelector('.home-about-eyebrow'),
      about.querySelector('.home-about-title'),
      about.querySelector('.home-about-excerpt'),
      about.querySelector('.button-wrapper'),
    ].filter(Boolean);

    /* Collage images rise into place and settle, then drift with a gentle parallax.
       dy = how far below its resting spot the image starts (px); dx = small lateral
       offset; depth = bounded parallax travel after it settles (px, signed for depth);
       lo = stagger start (scroll progress). The JS drives `transform`; the CSS
       `translate` float + `scale` hover compose on top without conflict. */
    var imgCfg = [
      { sel: '.about-image.one',   dx: -26, dy:  92, depth: -14, lo: 0.42 },
      { sel: '.about-image.three', dx:  26, dy:  92, depth:  10, lo: 0.49 },
      { sel: '.about-image.two',   dx: -20, dy: 112, depth:  -8, lo: 0.56 },
      { sel: '.about-image.four',  dx:  20, dy: 112, depth:  14, lo: 0.63 },
      { sel: '.about-image.five',  dx:   0, dy: 132, depth:  -6, lo: 0.70 },
    ].map(function (c) { c.el = about.querySelector(c.sel); return c; })
     .filter(function (c) { return c.el; });

    function clamp(v, a, b) { return v < a ? a : v > b ? b : v; }
    function ramp(v, lo, hi) { return clamp((v - lo) / (hi - lo), 0, 1); }
    function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
    function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); } /* slow, graceful settle */
    function smoothstep(t)   { return t * t * (3 - 2 * t); }    /* eased fade for the overlay */

    function initDesktop() {
      /* hide about content so it can be driven by scroll progress */
      els.forEach(function (el, i) {
        el.style.opacity   = '0';
        el.style.transform = 'translateY(42px)';
        if (i === 1) el.style.filter = 'blur(8px)'; /* headline focuses in (matches hero) */
      });
      imgCfg.forEach(function (c) {
        c.el.style.opacity   = '0';
        c.el.style.transform = 'translate(' + c.dx + 'px,' + c.dy + 'px) scale(0.92)';
      });
      overlay.style.opacity = '0';
    }

    function update() {
      var rect   = wrapper.getBoundingClientRect();
      var travel = wrapper.offsetHeight - window.innerHeight;
      if (travel <= 0) return;
      var p = clamp(-rect.top, 0, travel) / travel;

      /* phase 1 (p 0→0.5): warm-ink overlay eases in over the hero */
      overlay.style.opacity = String(smoothstep(ramp(p, 0, 0.5)));

      /* phase 2 (p 0.42→…, staggered): images rise + scale into place, then parallax-drift.
         Wider per-image window (0.22) + easeOutQuart = a slow, graceful settle. */
      imgCfg.forEach(function (c) {
        var raw = ramp(p, c.lo, c.lo + 0.22);
        var ep  = easeOutQuart(raw);
        c.el.style.opacity = String(clamp(raw * 1.5, 0, 1)); /* fade in a touch ahead of travel */
        var ix    = (c.dx * (1 - ep)).toFixed(1);
        /* once settled, drift slowly with remaining scroll for depth (bounded by `depth`) */
        var drift = c.depth * clamp((p - c.lo) / (1 - c.lo), 0, 1);
        var iy    = (c.dy * (1 - ep) + drift).toFixed(1);
        var sc    = (0.92 + 0.08 * ep).toFixed(3);
        c.el.style.transform = 'translate(' + ix + 'px,' + iy + 'px) scale(' + sc + ')';
      });

      /* phase 3 (p 0.40→…, staggered): about content eases up + fades in (headline unblurs) */
      els.forEach(function (el, i) {
        var lo = 0.40 + i * 0.06;
        var ep = easeOutCubic(ramp(p, lo, lo + 0.24));
        el.style.opacity   = String(ep);
        el.style.transform = 'translateY(' + (42 * (1 - ep)).toFixed(1) + 'px)';
        if (i === 1) el.style.filter = 'blur(' + (8 * (1 - ep)).toFixed(2) + 'px)';
      });
    }

    function reset() {
      overlay.style.opacity = '';
      els.forEach(function (el) {
        el.style.opacity   = '';
        el.style.transform = '';
        el.style.filter    = '';
      });
      imgCfg.forEach(function (c) {
        c.el.style.opacity   = '';
        c.el.style.transform = '';
      });
    }

    var active = false;

    function checkBreakpoint() {
      /* Reduced motion: no pinned reveal — keep overlay + about content visible at rest. */
      if (REDUCE_MOTION) { reset(); return; }
      if (window.innerWidth > 991) {
        if (!active) {
          active = true;
          initDesktop();
          window.addEventListener('scroll', update, { passive: true });
        }
        update();
      } else {
        if (active) {
          active = false;
          window.removeEventListener('scroll', update);
          reset();
        }
      }
    }

    window.addEventListener('resize', checkBreakpoint, { passive: true });
    checkBreakpoint();
  })();

  /* ── Home hero marquee: continuous RAF-based horizontal scroll ── */
  (function () {
    var hero = document.querySelector('.home-hero-marquee');
    if (!hero || REDUCE_MOTION) return;
    var inners = Array.from(hero.querySelectorAll('.home-hero-marquee-inner'));
    if (!inners.length) return;
    var pos = 0;
    var speed = 0.6;
    var totalW = 0;
    var paused = false;
    function getWidth() { totalW = inners[0].scrollWidth; }
    getWidth();
    window.addEventListener('resize', getWidth);
    hero.addEventListener('mouseenter', function () { paused = true; });
    hero.addEventListener('mouseleave', function () { paused = false; });
    function tick() {
      if (!paused) {
        pos -= speed;
        if (Math.abs(pos) >= totalW) pos = 0;
        inners.forEach(function (inner) {
          inner.style.transform = 'translateX(' + pos + 'px)';
        });
      }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  })();
</script>

<script>
  /* ── Bundle & Save: add every bundle product to the cart in one click ── */
  import { addToCart, type CartItem } from '@/lib/cart';

  const bundleBtn = document.getElementById('bundleAddToCartBtn') as HTMLButtonElement | null;
  if (bundleBtn) {
    const textEl = bundleBtn.querySelector('.button-text');
    const defaultLabel = textEl?.textContent || 'Add Bundle to Cart';
    let resetTimer: number | undefined;

    bundleBtn.addEventListener('click', () => {
      let items: CartItem[] = [];
      try {
        items = JSON.parse(bundleBtn.dataset.bundleItems || '[]');
      } catch {
        items = [];
      }
      if (!items.length) return;

      items.forEach((item) => addToCart(item));

      // Brief confirmation state, then open the drawer so the user sees the result
      window.clearTimeout(resetTimer);
      bundleBtn.classList.add('is-added');
      bundleBtn.disabled = true;
      if (textEl) textEl.textContent = `Added ${items.length} Items ✓`;
      resetTimer = window.setTimeout(() => {
        bundleBtn.classList.remove('is-added');
        bundleBtn.disabled = false;
        if (textEl) textEl.textContent = defaultLabel;
      }, 1500);

      if (typeof (window as any).__dojeenOpenCart === 'function') {
        (window as any).__dojeenOpenCart();
      }
    });
  }
</script>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
---

<BaseLayout title="Page Not Found — Dojeen" description="The page you were looking for could not be found." noIndex={true}>
  <Header variant="default" />
  <main class="main-wrapper">

    <section class="utility-section">
      <div class="section-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="content-wrapper-404">
            <div class="content-block-404">
              <div class="text-404">4<span class="span-404">0</span>4</div>
              <h2>Page Not Found</h2>
              <div class="excerpt-404">Please return to the site's homepage. It looks like nothing was found at this location.</div>
              <a href="/" class="primary-button w-inline-block">
                <div class="button-text-block">
                  <div class="button-text">Go Back to Home</div>
                </div>
                <div class="button-bg"></div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ProductCard from '@/components/sections/ProductCard.astro';
import { swatchColor, isLightSwatch } from '@/lib/colors';
import { img, sizedImg, srcSet } from '@/lib/img';
import { formatMoney } from '@/lib/money';
import { getProductBySlug, getRelatedProducts, getComplementaryProducts } from '@/lib/catalog';
import { testimonials } from '@/data/testimonials';

// "Only N left" shows once a variant's stock is at or below this (and above 0).
const LOW_STOCK_THRESHOLD = 10;

const slug = Astro.params.slug!;
const product = await getProductBySlug(slug);
if (!product) {
  return Astro.redirect('/404');
}

// Fetch up to 10 related products (Shopify's recommendations cap) so the slider
// has more than the 4 shown per view on desktop — otherwise there's nothing to
// scroll and the arrows appear inert.
const [relatedProducts, completeTheLook] = product.shopifyId
  ? await Promise.all([
      getRelatedProducts(product.shopifyId, 10),
      getComplementaryProducts(product.shopifyId, 4),
    ])
  : [[], []];

// Initial low-stock state for the default variant (the client re-evaluates per
// selection). Null quantity = store doesn't expose inventory → no indicator.
const defaultVariant =
  product.variantMatrix?.find((v) => v.id === product.variantId) ?? product.variantMatrix?.[0];
const initialQty = defaultVariant?.quantity ?? null;
const showInitialLowStock =
  product.inStock && initialQty != null && initialQty > 0 && initialQty <= LOW_STOCK_THRESHOLD;
const allImages = [product.thumbnail, product.thumbnailHover, ...product.images].filter(
  (im, idx, arr) => im && arr.indexOf(im) === idx
);
// Long descriptions get clamped to a teaser in the buy rail (full copy lives in the
// "Product Information's" accordion); short ones render in full with no "Read more".
const isLongDesc = (product.description?.length ?? 0) > 220;

// Compact snapshot of this product for the client-side "Recently Viewed" history
// (image URLs pre-resolved so the section renders without any server round-trip).
const recentSnapshot = {
  slug: product.slug,
  name: product.name,
  price: product.price,
  currencyCode: product.currencyCode,
  isOnSale: !!product.isOnSale,
  comparePrice: product.comparePrice ?? null,
  discount: product.discount ?? 0,
  thumbnail: img(product.thumbnail),
  thumbnailHover: img(product.thumbnailHover || product.thumbnail),
};

// Wishlist snapshot (adds variantId/inStock so the wishlist page can add to cart).
const wishItem = { ...recentSnapshot, variantId: product.variantId, inStock: product.inStock };
---

<BaseLayout
  title={`${product.name} — Dojeen`}
  description={product.description}
  ogImage={product.thumbnail || '/og-image.jpg'}
>
  <Header variant="default" currentPath={Astro.url.pathname} />
  <main id="main-content" class="main-wrapper">

    <!-- Product Details Section -->
    <section class="product-details-section page-top-gap">
      <div class="cms-hero-gap">
        <div class="w-layout-blockcontainer container-default w-container">
          <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="pdp-breadcrumb-sep" aria-hidden="true">/</span>
            <a href="/shop">Shop</a>
            {product.category && (
              <>
                <span class="pdp-breadcrumb-sep" aria-hidden="true">/</span>
                <a href={`/shop/category/${product.categorySlug}`}>{product.category}</a>
              </>
            )}
            <span class="pdp-breadcrumb-sep" aria-hidden="true">/</span>
            <span class="pdp-breadcrumb-current" aria-current="page">{product.name}</span>
          </nav>
          <div class="prodcut-details-wrapper">

            <!-- Left: Images + Accordion -->
            <div class="product-details-left-block">
              <!-- Image Gallery (all 3 visible in 2-col grid, matching Webflow) -->
              <div class="product-lightbox-wrapper">
                {allImages.slice(0, 3).map((im) => (
                  <a href={sizedImg(im, 1600)} class="product-lightbox w-inline-block">
                    <img
                      loading="lazy"
                      src={sizedImg(im, 700)}
                      srcset={srcSet(im, [400, 700, 1000]) || undefined}
                      sizes="(max-width: 991px) 90vw, 340px"
                      alt={product.name}
                      class="product-image"
                    />
                  </a>
                ))}
              </div>

              <!-- Accordions -->
              <div class="product-accordion-wrapper">
                <div class="product-accordion" data-accordion>
                  <div class="product-accordion-toggle" data-accordion-toggle>
                    <div class="product-accordion-title-block">
                      <img src="/images/product-accordion-icon-1.svg" loading="lazy" alt="" class="product-accordion-icon" />
                      <div class="product-accordion-title">Product Information's</div>
                    </div>
                    <img src="/images/accordion-arrow.svg" loading="lazy" alt="" class="product-accordion-arrow" />
                  </div>
                  <div class="product-accordion-body" style="height:0px" data-accordion-body>
                    <div class="product-accordion-inner">
                      <div class="product-information w-richtext">
                        <p>{product.description}</p>
                        {product.careInstructions && (
                          <p><strong>Care:</strong> {product.careInstructions}</p>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
                <div class="product-accordion" data-accordion>
                  <div class="product-accordion-toggle" data-accordion-toggle>
                    <div class="product-accordion-title-block">
                      <img src="/images/product-accordion-icon-2.svg" loading="lazy" alt="" class="product-accordion-icon" />
                      <div class="product-accordion-title">Size Advice</div>
                    </div>
                    <img src="/images/accordion-arrow.svg" loading="lazy" alt="" class="product-accordion-arrow" />
                  </div>
                  <div class="product-accordion-body" style="height:0px" data-accordion-body>
                    <div class="product-accordion-inner">
                      <div class="product-size-guide w-richtext">
                        <p>We want you to find the perfect fit. Since sizing can vary between styles, please check our size chart before purchasing.</p>
                        <ul role="list">
                          <li><strong>Measure Yourself:</strong> Use a soft tape to measure your bust, waist, and hips.</li>
                          <li><strong>Compare with Chart:</strong> Match your measurements with our guide to pick the closest size.</li>
                          <li><strong>Sizing Guide:</strong>
                            <ul role="list">
                              <li><strong>S (Small):</strong> Best for bust 32–34&quot;, waist 24–26&quot;, hips 34–36&quot;.</li>
                              <li><strong>M (Medium):</strong> Best for bust 35–36&quot;, waist 27–28&quot;, hips 37–38&quot;.</li>
                              <li><strong>L (Large):</strong> Best for bust 37–39&quot;, waist 29–31&quot;, hips 39–41&quot;.</li>
                              <li><strong>XL (Extra Large):</strong> Best for bust 40–42&quot;, waist 32–34&quot;, hips 42–44&quot;.</li>
                            </ul>
                          </li>
                          <li><strong>Between Sizes?</strong> Choose the larger size for comfort.</li>
                          <li><strong>Fit Preference:</strong> One size down for a snug fit, or up for a relaxed fit.</li>
                          <li><strong>Unsure?</strong> Our customer care team is here to help you choose.</li>
                        </ul>
                        <p>Tip: Stretch fabrics may feel looser, while structured styles fit more snugly.</p>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="product-accordion" data-accordion>
                  <div class="product-accordion-toggle" data-accordion-toggle>
                    <div class="product-accordion-title-block">
                      <img src="/images/product-accordion-icon-1.svg" loading="lazy" alt="" class="product-accordion-icon" />
                      <div class="product-accordion-title">Shipping &amp; Returns</div>
                    </div>
                    <img src="/images/accordion-arrow.svg" loading="lazy" alt="" class="product-accordion-arrow" />
                  </div>
                  <div class="product-accordion-body" style="height:0px" data-accordion-body>
                    <div class="product-accordion-inner">
                      <div class="shipping-and-return w-richtext">
                        <ul role="list">
                          <li>Orders are processed within 1–2 business days.</li>
                          <li>Delivery takes 3–7 business days depending on location.</li>
                          <li>Tracking details are emailed once shipped.</li>
                          <li>Returns are accepted within 14 days of delivery.</li>
                          <li>Items must be unused and in original packaging.</li>
                          <li>Return shipping costs apply unless the item is defective.</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right: Product Info -->
            <div class="product-details-right-block">
              <!-- Rating: real reviews show stars + count; otherwise an honest "New In" eyebrow
                   (the demo store has no review data, so fake 5-star rows are avoided). -->
              {product.reviewCount > 0 ? (
                <div class="product-review-wrapper">
                  <div class="product-star-rating-block">
                    <div style="display:flex;gap:3px;align-items:center;">
                      {Array.from({ length: Math.floor(product.rating) }).map(() => (
                        <img src="/images/star-full.svg" alt="" style="width:20px;height:20px;display:block;" />
                      ))}
                      {product.rating % 1 >= 0.5 && (
                        <img src="/images/star-half.svg" alt="" style="width:20px;height:20px;display:block;" />
                      )}
                    </div>
                    <div class="product-star-rating-text">({product.rating})</div>
                  </div>
                  <div class="product-details-review-separator"></div>
                  <div class="product-reveiw-amonut">{product.reviewCount} Reviews</div>
                </div>
              ) : (
                <div class="pdp-eyebrow">New In</div>
              )}

              <h1 class="product-title">{product.name}</h1>

              <!-- Pricing -->
              <div class="product-details-pricing-wrapper">
                <div class="product-details-pricing-block">
                  {product.isOnSale ? (
                    <>
                      <div class="product-details-price">{formatMoney(product.price, product.currencyCode)}</div>
                      <div class="product-details-pricing-separator"></div>
                      <div class="product-details-compare-price">{formatMoney(product.comparePrice ?? product.price, product.currencyCode)}</div>
                    </>
                  ) : (
                    <div class="product-details-price">{formatMoney(product.price, product.currencyCode)}</div>
                  )}
                </div>
                {product.isOnSale && <div class="sale-badge">Sale</div>}
              </div>

              <!-- Stock -->
              {product.inStock ? (
                <div class="stock-alert">
                  <div class="stock-alert-shape-block">
                    <div class="stock-alert-shape-wave"></div>
                  </div>
                  <div class="stock-alert-text">In Stock, Ready to ship</div>
                </div>
              ) : (
                <div class="stock-alert stock-alert-out">
                  <div class="stock-alert-text">Currently sold out</div>
                </div>
              )}

              <!-- Honest low-stock urgency (from real per-variant inventory; hidden
                   unless a variant is genuinely low). Updated client-side per selection. -->
              <div
                class="pdp-low-stock"
                id="pdpLowStock"
                data-threshold={LOW_STOCK_THRESHOLD}
                hidden={!showInitialLowStock}
              >
                <span class="pdp-low-stock-dot"></span>
                <span class="pdp-low-stock-text">
                  {showInitialLowStock ? `Only ${initialQty} left in stock` : ''}
                </span>
              </div>

              <!-- Delivery estimate (date window computed client-side from today;
                   reflects the selected variant's availability). -->
              <div class="pdp-delivery" id="pdpDelivery" hidden>
                <span class="pdp-delivery-icon-wrap">
                  <svg class="pdp-delivery-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 4h13v11H1z" />
                    <path d="M14 8h4l3 3v4h-7z" />
                    <circle cx="6" cy="18" r="1.7" />
                    <circle cx="18" cy="18" r="1.7" />
                  </svg>
                </span>
                <span class="pdp-delivery-copy">
                  <span class="pdp-delivery-label">Estimated delivery</span>
                  <span class="pdp-delivery-text" id="pdpDeliveryText"></span>
                </span>
              </div>

              <!-- Description (teaser — full copy + care notes in the accordion below) -->
              <div class="pdp-description-wrap">
                <p class={`product-description${isLongDesc ? ' pdp-description-clamp' : ''}`} id="pdpDescription">{product.description}</p>
                {isLongDesc && (
                  <button type="button" class="pdp-readmore" id="pdpReadMore">
                    Read more <span aria-hidden="true">&#8594;</span>
                  </button>
                )}
              </div>

              <!-- Add to Cart -->
              <div class="product-details-add-to-cart">

                <!-- Color + Size selectors (Color first, matching Webflow order) -->
                <div class="product-option-list">
                  {product.colors.length > 0 && (
                    <div class="product-option">
                      <label class="product-option-label">Color: <span id="selectedColorLabel">{product.colors[0]}</span></label>
                      <div class="product-option-button-group pdp-swatch-group" id="colorSelector" role="group" aria-label="Choose a color">
                        {product.colors.map((color, idx) => (
                          <button
                            class={`pdp-color-swatch${idx === 0 ? ' active' : ''}${isLightSwatch(color) ? ' is-light' : ''}`}
                            data-color={color}
                            title={color}
                            aria-label={color}
                            aria-pressed={idx === 0 ? 'true' : 'false'}
                            style={`--swatch:${swatchColor(color)}`}
                          >
                            <span class="visually-hidden">{color}</span>
                          </button>
                        ))}
                      </div>
                    </div>
                  )}
                  {product.sizes.length > 0 && (
                    <div class="product-option">
                      <label class="product-option-label">Size</label>
                      <div class="product-option-button-group" id="sizeSelector">
                        {product.sizes.map((size, idx) => (
                          <button
                            class={`product-size-btn${idx === 0 ? ' active' : ''}`}
                            data-size={size}
                          >
                            {size}
                          </button>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                <!-- Meta (with product-meta-icon matching Webflow) -->
                <div class="product-meta-wrapper">
                  {product.sku && (
                    <div class="product-meta-block">
                      <div class="product-meta-icon"></div>
                      <div class="product-meta-title">SKU:</div>
                      <div class="product-meta-text">{product.sku}</div>
                    </div>
                  )}
                  <div class="product-meta-block">
                    <div class="product-meta-icon"></div>
                    <div class="product-meta-title">Category:</div>
                    <div class="product-meta-text">
                      <a href={`/shop/category/${product.categorySlug}`}>{product.category}</a>
                    </div>
                  </div>
                </div>

                <!-- Quantity + Add to Cart -->
                <div class="add-to-cart-button-wrapper">
                  <label for="productQty" class="product-option-label">Quantity</label>
                  <div class="product-add-to-cart-block">
                    <div class="pdp-qty-stepper">
                      <button type="button" class="pdp-qty-btn" id="qtyMinus" aria-label="Decrease quantity">&#8722;</button>
                      <input
                        type="number"
                        id="productQty"
                        min="1"
                        value="1"
                        class="w-commerce-commerceaddtocartquantityinput quantity"
                      />
                      <button type="button" class="pdp-qty-btn" id="qtyPlus" aria-label="Increase quantity">&#43;</button>
                    </div>
                    <button
                      class="w-commerce-commerceaddtocartbutton add-to-card-button"
                      id="addToCartBtn"
                      data-variant-id={product.variantId}
                      data-variants={JSON.stringify(product.variantMatrix ?? [])}
                      disabled={!product.inStock}
                    >
                      {product.inStock ? 'Add to Cart' : 'Sold Out'}
                    </button>
                  </div>
                  <button type="button" id="buyNowBtn" class="w-commerce-commercebuynowbutton buy-now-button" disabled={!product.inStock}>Buy now</button>
                  <button
                    class="wishlist-heart-btn pdp-wishlist-btn"
                    type="button"
                    data-slug={product.slug}
                    data-wishlist={JSON.stringify(wishItem)}
                    aria-label="Add to wishlist"
                    aria-pressed="false"
                  >
                    <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
                    </svg>
                    <span class="wishlist-label">Add to Wishlist</span>
                  </button>
                </div>

                <!-- Trust badges -->
                <ul class="pdp-trust-row">
                  <li class="pdp-trust-item">
                    <span class="pdp-trust-icon-wrap"><img src="/images/feature-icon-1.svg" loading="lazy" alt="" class="pdp-trust-icon" /></span>
                    <span>Free worldwide shipping</span>
                  </li>
                  <li class="pdp-trust-item">
                    <span class="pdp-trust-icon-wrap"><img src="/images/feature-icon-2.svg" loading="lazy" alt="" class="pdp-trust-icon" /></span>
                    <span>Secure checkout</span>
                  </li>
                  <li class="pdp-trust-item">
                    <span class="pdp-trust-icon-wrap"><img src="/images/feature-icon-3.svg" loading="lazy" alt="" class="pdp-trust-icon" /></span>
                    <span>30-day easy returns</span>
                  </li>
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- Complete the Look (complementary cross-sell — Shopify COMPLEMENTARY intent) -->
    {completeTheLook.length > 0 && (
      <section class="product-section">
        <div class="section-gap-bottom">
          <div class="w-layout-blockcontainer container-default w-container">
            <div class="section-title-block center">
              <div class="section-subtitle reveal">Styled With</div>
              <div class="section-title-inner">
                <h2 class="section-title reveal">Complete the Look</h2>
              </div>
            </div>
            <div class="complete-look-grid">
              {completeTheLook.map((p) => (
                <div class="product-card-block">
                  <ProductCard product={p} headingTag="h3" />
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Related Products (slider matching Webflow structure) -->
    {relatedProducts.length > 0 && (
      <section class="product-section">
        <div class="section-gap-bottom">
          <div class="w-layout-blockcontainer container-default w-container">
            <div class="section-title-block center">
              <div class="section-title-inner">
                <h2 class="section-title">Related Products</h2>
              </div>
            </div>
            <div class="product-slider w-slider" id="relatedSlider" style="overflow:hidden;position:relative;">
              <div class="left-overlay"></div>
              <div class="right-overlay"></div>
              <div class="product-slider-mask w-slider-mask" id="relatedMask" style="display:flex;flex-wrap:nowrap;transition:transform 0.4s ease;">
                {relatedProducts.map((p) => (
                  <div class="product-slider-item w-slide">
                    <div class="product-collection-list w-dyn-list">
                      <div role="list" class="product-slider-item-wrapper w-dyn-items">
                        <div role="listitem" class="product-collection-item w-dyn-item">
                          <div class="product-card-block">
                            <ProductCard product={p} headingTag="h3" />
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="product-slider-arrow left w-slider-arrow-left" id="relatedPrev">
                <div class="product-slider-arrow-icon w-icon-slider-left"></div>
              </div>
              <div class="product-slider-arrow right w-slider-arrow-right" id="relatedNext">
                <div class="product-slider-arrow-icon w-icon-slider-right"></div>
              </div>
              <div class="hidden-slider-nav w-slider-nav w-round w-num"></div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Testimonials (static social proof — reuses the homepage card design as a grid) -->
    <section class="pdp-testimonial-section">
      <div class="section-gap-bottom">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="section-title-block center">
            <div class="section-subtitle reveal">Testimonial</div>
            <div class="section-title-inner">
              <h2 class="section-title reveal">What Customers Say</h2>
            </div>
          </div>
          <div class="pdp-testimonial-grid">
            {testimonials.map((t) => (
              <div class="testimonial-card-block">
                <div class="testimonial-content-wrapper">
                  <div class="testimonial-content-block">
                    <div class="testimonial-author-info-block">
                      <div class="testimonial-reveiw-wrapper">
                        <div class="testimonial-reveiw-block">
                          {Array.from({ length: Math.floor(t.rating) }).map(() => (
                            <img src="/images/star-full.svg" loading="lazy" alt="Testimonial Star" class="testimonial-star" />
                          ))}
                          {t.rating % 1 >= 0.5 && (
                            <img src="/images/star-half.svg" loading="lazy" alt="Testimonial Star" class="testimonial-star" />
                          )}
                          {Array.from({ length: 5 - Math.ceil(t.rating) }).map(() => (
                            <img src="/images/star.svg" loading="lazy" alt="Testimonial Star" class="testimonial-star" />
                          ))}
                        </div>
                        <div class="testimonial-rating-text">({t.rating.toFixed(1)})</div>
                      </div>
                      <div class="testimonial-author-info">
                        <div class="testimonial-author-name">{t.name}</div>
                        <div class="testimonial-author-info-dash"></div>
                        <div class="testimonial-author-designation">{t.designation}</div>
                      </div>
                    </div>
                    <p class="testimonial-author-text">{t.quote}</p>
                  </div>
                  <div class="testimonial-image-block">
                    <img src={`/images/${t.image}`} loading="lazy" alt={t.name} class="testimonial-image" />
                  </div>
                </div>
                <div class="testimonial-border"></div>
                <div class="testimonial-product-wrapper w-dyn-list">
                  <div role="list" class="testimonial-product-list w-dyn-items">
                    <div role="listitem" class="testimonial-product-item w-dyn-item">
                      <div class="testimonial-product-block">
                        <a href={`/products/${t.productSlug}`} class="testimonial-product-thumbnail-block w-inline-block">
                          <img loading="lazy" src={`/images/${t.productThumbnail}`} alt={t.productName} class="testimonial-product-thumbnail" />
                        </a>
                        <div class="testimonial-product-info-block">
                          <a href={`/products/${t.productSlug}`} class="product-link-block w-inline-block">
                            <div class="product-name">{t.productName}</div>
                          </a>
                          <div class="product-card-pricing-block">
                            <div class="product-card-sale-price">${t.productPrice.toFixed(2)}</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Recently Viewed (hidden until the client finds prior history in localStorage) -->
    <section
      class="product-section recently-viewed-section"
      id="recentlyViewedSection"
      data-product-snapshot={JSON.stringify(recentSnapshot)}
      hidden
    >
      <div class="section-gap-bottom">
        <div class="w-layout-blockcontainer container-default w-container">
          <div class="section-title-block center">
            <div class="section-title-inner">
              <h2 class="section-title">Recently Viewed</h2>
            </div>
          </div>
          <div class="recently-viewed-grid" id="recentlyViewedGrid"></div>
        </div>
      </div>
    </section>

    <!-- Lightbox modal (vanilla JS, no dependency) -->
    <div class="pdp-lightbox" id="pdpLightbox" role="dialog" aria-modal="true" aria-label="Product image viewer" aria-hidden="true">
      <button type="button" class="pdp-lightbox-close" id="pdpLightboxClose" aria-label="Close image viewer">&#10005;</button>
      <button type="button" class="pdp-lightbox-nav prev" id="pdpLightboxPrev" aria-label="Previous image">&#8249;</button>
      <img src="" alt={product.name} class="pdp-lightbox-img" id="pdpLightboxImg" />
      <button type="button" class="pdp-lightbox-nav next" id="pdpLightboxNext" aria-label="Next image">&#8250;</button>
    </div>

    <!-- Sticky add-to-cart bar — appears (mobile + desktop) once the buy box scrolls off -->
    <div class="pdp-sticky-bar" id="pdpStickyBar" aria-hidden="true">
      <div class="pdp-sticky-inner w-layout-blockcontainer container-default w-container">
        <a href={`/products/${product.slug}`} class="pdp-sticky-product">
          <img src={sizedImg(product.thumbnail, 120)} alt={product.name} class="pdp-sticky-thumb" />
          <span class="pdp-sticky-meta">
            <span class="pdp-sticky-name">{product.name}</span>
            <span class="pdp-sticky-price">
              {formatMoney(product.price, product.currencyCode)}
              {product.isOnSale && (
                <span class="pdp-sticky-compare">{formatMoney(product.comparePrice ?? product.price, product.currencyCode)}</span>
              )}
            </span>
          </span>
        </a>
        <button
          class="w-commerce-commerceaddtocartbutton add-to-card-button pdp-sticky-btn"
          id="pdpStickyAdd"
          data-variant-id={product.variantId}
          disabled={!product.inStock}
        >
          {product.inStock ? 'Add to Cart' : 'Sold Out'}
        </button>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
  .stock-alert-out .stock-alert-text { color: var(--_color---red-500, #d0473e); }
  .add-to-card-button:disabled,
  .buy-now-button:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<script>
  import { addItem, goToCheckout } from '@/lib/cart';

  // Size selector
  const sizeSelector = document.getElementById('sizeSelector');
  let selectedSize = '';
  if (sizeSelector) {
    const firstBtn = sizeSelector.querySelector<HTMLElement>('[data-size]');
    if (firstBtn) selectedSize = firstBtn.getAttribute('data-size') || '';
    sizeSelector.querySelectorAll<HTMLElement>('[data-size]').forEach((btn) => {
      btn.addEventListener('click', () => {
        sizeSelector!.querySelectorAll('[data-size]').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        selectedSize = btn.getAttribute('data-size') || '';
      });
    });
  }

  // Color selector
  const colorSelector = document.getElementById('colorSelector');
  const colorLabel = document.getElementById('selectedColorLabel');
  let selectedColor = '';
  if (colorSelector) {
    const firstBtn = colorSelector.querySelector<HTMLElement>('[data-color]');
    if (firstBtn) selectedColor = firstBtn.getAttribute('data-color') || '';
    colorSelector.querySelectorAll<HTMLElement>('[data-color]').forEach((btn) => {
      btn.addEventListener('click', () => {
        colorSelector!.querySelectorAll('[data-color]').forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        selectedColor = btn.getAttribute('data-color') || '';
        if (colorLabel) colorLabel.textContent = selectedColor;
      });
    });
  }

  // Quantity stepper
  const qtyInputEl = document.getElementById('productQty') as HTMLInputElement | null;
  function clampQty(v: number) { return Number.isFinite(v) && v >= 1 ? Math.floor(v) : 1; }
  function setQty(v: number) { if (qtyInputEl) qtyInputEl.value = String(clampQty(v)); }
  document.getElementById('qtyMinus')?.addEventListener('click', () => {
    setQty(parseInt(qtyInputEl?.value || '1', 10) - 1);
  });
  document.getElementById('qtyPlus')?.addEventListener('click', () => {
    setQty(parseInt(qtyInputEl?.value || '1', 10) + 1);
  });
  qtyInputEl?.addEventListener('change', () => setQty(parseInt(qtyInputEl.value || '1', 10)));

  // Resolve the selected (size, color) to a Shopify variant + reflect availability.
  interface VariantOption { id: string; available: boolean; quantity?: number | null; options: Record<string, string> }
  const addToCartBtn = document.getElementById('addToCartBtn') as HTMLButtonElement | null;
  const buyNowBtn = document.getElementById('buyNowBtn') as HTMLButtonElement | null;
  const stickyAddBtn = document.getElementById('pdpStickyAdd') as HTMLButtonElement | null;
  const lowStockEl = document.getElementById('pdpLowStock');
  const lowStockTextEl = lowStockEl?.querySelector('.pdp-low-stock-text') as HTMLElement | null;
  const lowStockThreshold = Number(lowStockEl?.getAttribute('data-threshold') || '10');
  const addDefaultLabel = 'Add to Cart';
  let variantMatrix: VariantOption[] = [];
  try {
    variantMatrix = JSON.parse(addToCartBtn?.getAttribute('data-variants') || '[]');
  } catch {
    variantMatrix = [];
  }
  const defaultVariantId = addToCartBtn?.getAttribute('data-variant-id') || '';
  // Single-variant availability: the server set the button disabled when out of stock.
  const productInStock = !(addToCartBtn?.disabled ?? false);

  // ── Delivery estimate: a business-day window from today ──
  const deliveryEl = document.getElementById('pdpDelivery');
  const deliveryTextEl = document.getElementById('pdpDeliveryText');
  function addBusinessDays(from: Date, days: number): Date {
    const d = new Date(from.getTime());
    let added = 0;
    while (added < days) {
      d.setDate(d.getDate() + 1);
      const wd = d.getDay();
      if (wd !== 0 && wd !== 6) added++;
    }
    return d;
  }
  if (deliveryTextEl) {
    const now = new Date();
    const fmt = (d: Date) =>
      d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
    deliveryTextEl.textContent =
      fmt(addBusinessDays(now, 3)) + ' – ' + fmt(addBusinessDays(now, 7));
  }

  function findVariant(): VariantOption | null {
    if (!variantMatrix.length) return null;
    return (
      variantMatrix.find((v) => {
        if (selectedSize && (v.options.size ?? '') !== selectedSize) return false;
        if (selectedColor && (v.options.color ?? '') !== selectedColor) return false;
        return true;
      }) ?? null
    );
  }
  function resolveVariantId(): string {
    if (!variantMatrix.length) return defaultVariantId;
    return (findVariant() ?? variantMatrix[0]).id;
  }

  // Honest "Only N left" — reflects the selected variant's real inventory.
  function updateLowStock(): void {
    if (!lowStockEl || !lowStockTextEl) return;
    const qty = variantMatrix.length ? findVariant()?.quantity : null;
    if (qty != null && qty > 0 && qty <= lowStockThreshold) {
      lowStockTextEl.textContent = `Only ${qty} left in stock`;
      lowStockEl.hidden = false;
    } else {
      lowStockEl.hidden = true;
    }
  }

  // Reflect the selected variant's stock state on every buy button + the low-stock note.
  function updateAddState(): void {
    const available = variantMatrix.length ? (findVariant()?.available ?? false) : productInStock;
    if (variantMatrix.length) {
      [addToCartBtn, stickyAddBtn].forEach((btn) => {
        if (!btn || btn.classList.contains('is-added')) return;
        btn.disabled = !available;
        btn.textContent = available ? addDefaultLabel : 'Sold Out';
      });
      if (buyNowBtn) buyNowBtn.disabled = !available;
    }
    // Delivery estimate only makes sense for a buyable selection.
    if (deliveryEl) deliveryEl.hidden = !available;
    updateLowStock();
  }
  sizeSelector?.querySelectorAll<HTMLElement>('[data-size]').forEach((b) =>
    b.addEventListener('click', updateAddState),
  );
  colorSelector?.querySelectorAll<HTMLElement>('[data-color]').forEach((b) =>
    b.addEventListener('click', updateAddState),
  );
  updateAddState();

  // Shared add-to-cart with per-button feedback (drives both the main and sticky buttons).
  function wireAdd(btn: HTMLButtonElement): void {
    let resetTimer: number | undefined;
    btn.addEventListener('click', async () => {
      const variantId = resolveVariantId();
      if (!variantId) return;
      const qty = clampQty(parseInt(qtyInputEl?.value || '1', 10));
      btn.disabled = true;
      const { cart, error } = await addItem(variantId, qty);
      window.clearTimeout(resetTimer);
      if (cart) {
        btn.classList.add('is-added');
        btn.textContent = 'Added ✓';
      } else {
        btn.textContent = error ? 'Unavailable' : 'Try again';
      }
      resetTimer = window.setTimeout(() => {
        btn.classList.remove('is-added');
        btn.textContent = addDefaultLabel;
        btn.disabled = false;
        updateAddState();
      }, 1200);
    });
  }
  if (addToCartBtn) wireAdd(addToCartBtn);
  if (stickyAddBtn) wireAdd(stickyAddBtn);

  // Buy now: add then jump straight to Shopify's hosted checkout.
  if (buyNowBtn) {
    buyNowBtn.addEventListener('click', async () => {
      const variantId = resolveVariantId();
      if (!variantId) return;
      const qty = clampQty(parseInt(qtyInputEl?.value || '1', 10));
      buyNowBtn.disabled = true;
      const { cart } = await addItem(variantId, qty, { open: false });
      if (cart) goToCheckout();
      else buyNowBtn.disabled = false;
    });
  }

  // Sticky bar: reveal once the main buy box has scrolled above the viewport.
  (function () {
    const bar = document.getElementById('pdpStickyBar');
    const anchor = document.querySelector('.add-to-cart-button-wrapper');
    if (!bar || !anchor || !('IntersectionObserver' in window)) return;
    const io = new IntersectionObserver(
      (entries) => {
        const e = entries[0];
        const show = !e.isIntersecting && e.boundingClientRect.top < 0;
        bar.classList.toggle('is-visible', show);
        bar.setAttribute('aria-hidden', show ? 'false' : 'true');
      },
      { threshold: 0 },
    );
    io.observe(anchor);
  })();
</script>

<script>
  // ── Recently Viewed: record this product, then render prior history ──
  import { recordRecent, renderRecentlyViewed } from '@/lib/recently-viewed';

  const rvSection = document.getElementById('recentlyViewedSection');
  if (rvSection) {
    let snap: any = null;
    try {
      snap = JSON.parse(rvSection.getAttribute('data-product-snapshot') || 'null');
    } catch {
      snap = null;
    }
    if (snap && snap.slug) recordRecent(snap);
    renderRecentlyViewed({
      section: rvSection,
      mount: document.getElementById('recentlyViewedGrid'),
      excludeSlug: snap?.slug,
      limit: 4,
    });
  }
</script>

<script is:inline>
  /* ── Description "Read more": expand the clamped teaser in place ── */
  (function () {
    var rm = document.getElementById('pdpReadMore');
    var desc = document.getElementById('pdpDescription');
    if (!rm || !desc) return;
    rm.addEventListener('click', function () {
      desc.classList.remove('pdp-description-clamp');
      rm.style.display = 'none';
    });
  })();

  /* ── Accordion ── */
  (function () {
    document.querySelectorAll('[data-accordion]').forEach(function (accordion) {
      var toggle = accordion.querySelector('[data-accordion-toggle]');
      var body = accordion.querySelector('[data-accordion-body]');
      if (!toggle || !body) return;
      toggle.addEventListener('click', function () {
        var isOpen = accordion.classList.contains('open');
        document.querySelectorAll('[data-accordion]').forEach(function (a) {
          a.classList.remove('open');
          var b = a.querySelector('[data-accordion-body]');
          if (b) b.style.height = '0px';
        });
        if (!isOpen) {
          accordion.classList.add('open');
          body.style.height = body.scrollHeight + 'px';
        }
      });
    });
  })();

  /* ── Related products slider (responsive: 4 desktop / 2 tablet / 1 mobile) ── */
  (function () {
    var slider = document.getElementById('relatedSlider');
    var mask = document.getElementById('relatedMask');
    var prev = document.getElementById('relatedPrev');
    var next = document.getElementById('relatedNext');
    if (!slider || !mask || !prev || !next) return;
    var slides = Array.from(mask.querySelectorAll('.product-slider-item'));
    if (!slides.length) return;
    var cur = 0;
    var total = slides.length;
    function slideW() { return slides[0].offsetWidth; }
    function visibleCount() {
      var sw = slideW();
      return sw > 0 ? Math.max(1, Math.round(slider.offsetWidth / sw)) : 1;
    }
    function maxCur() { return Math.max(0, total - visibleCount()); }
    function update() {
      var mc = maxCur();
      if (cur > mc) cur = mc;
      mask.style.transform = 'translateX(-' + (cur * slideW()) + 'px)';
      // Reflect bounds on the arrows (and hide them entirely if nothing scrolls).
      var noScroll = mc === 0;
      slider.classList.toggle('is-static', noScroll);
      prev.classList.toggle('is-disabled', cur <= 0);
      next.classList.toggle('is-disabled', cur >= mc);
    }
    prev.addEventListener('click', function () { if (cur > 0) { cur--; update(); } });
    next.addEventListener('click', function () { if (cur < maxCur()) { cur++; update(); } });
    window.addEventListener('resize', function () { cur = Math.min(cur, maxCur()); update(); });
    update(); // set initial transform + arrow state
  })();

  /* ── Gallery lightbox ── */
  (function () {
    var box = document.getElementById('pdpLightbox');
    var imgEl = document.getElementById('pdpLightboxImg');
    var closeBtn = document.getElementById('pdpLightboxClose');
    var prevBtn = document.getElementById('pdpLightboxPrev');
    var nextBtn = document.getElementById('pdpLightboxNext');
    if (!box || !imgEl) return;

    var links = Array.prototype.slice.call(document.querySelectorAll('.product-lightbox'));
    var srcs = links.map(function (a) { return a.getAttribute('href'); });
    var idx = 0;

    function show(i) {
      idx = (i + srcs.length) % srcs.length;
      imgEl.setAttribute('src', srcs[idx]);
    }
    function open(i) {
      show(i);
      box.classList.add('open');
      box.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (closeBtn) closeBtn.focus();
    }
    function close() {
      box.classList.remove('open');
      box.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    links.forEach(function (a, i) {
      a.addEventListener('click', function (e) { e.preventDefault(); open(i); });
    });
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (prevBtn) prevBtn.addEventListener('click', function () { show(idx - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { show(idx + 1); });
    box.addEventListener('click', function (e) { if (e.target === box) close(); });
    document.addEventListener('keydown', function (e) {
      if (!box.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  })();
</script>

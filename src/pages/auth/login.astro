---
export const prerender = false;
import { getSession } from '@/lib/customer/session';
// With the Customer Account API, Shopify hosts the login/register/reset UI.
// Send signed-in users to their account; everyone else into the OAuth flow.
return Astro.redirect(
  getSession(Astro.cookies) ? '/account' : '/api/auth/login?returnTo=/account',
);
---

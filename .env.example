# ─────────────────────────────────────────────────────────────
#  Shopify Storefront API — SERVER-SIDE secrets (copy to .env).
#  No PUBLIC_ prefix => kept on the server only, never shipped to
#  the browser. The storefront proxies all Shopify calls via
#  same-origin /api/* routes using the private token.
# ─────────────────────────────────────────────────────────────

# Your store's myshopify domain, e.g. your-shop.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com

# Storefront API private (delegate) access token — server only.
# Header used: Shopify-Storefront-Private-Token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# Pin the API version. Do not use unversioned URLs.
SHOPIFY_API_VERSION=2026-04

# ─────────────────────────────────────────────────────────────
#  Customer Account API — customer login / account (OAuth + PKCE).
#  From the admin: Settings → Customer accounts → Customer Account
#  API. Public client (Client ID only, no secret). Register the
#  callback URI ({origin}/account/authorize) and a logout URI
#  ({origin}/) in the Application setup before testing.
# ─────────────────────────────────────────────────────────────

# Customer Account API Client ID.
CUSTOMER_ACCOUNT_API_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your store's numeric Shop ID (shown in the Customer Account API settings).
SHOPIFY_SHOP_ID=000000000000

# Customer Account API version — one of 2025-07, 2025-10, 2026-01, 2026-04, 2026-07.
CUSTOMER_ACCOUNT_API_VERSION=2026-04

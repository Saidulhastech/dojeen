{
  "name": "dojeen",
  "type": "module",
  "version": "1.1.0",
  "description": "Dojeen — a modern fashion e-commerce Astro website template",
  "keywords": [
    "astro",
    "theme",
    "fashion",
    "ecommerce",
    "template",
    "clothing",
    "webflow"
  ],
  "author": {
    "name": "Aslam Hasib",
    "email": "hello@hasthemes.com",
    "url": "https://hasthemes.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "/",
  "repository": {
    "type": "git",
    "url": "#"
  },
  "bugs": {
    "url": "#",
    "email": "support@hasthemes.com"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:cloudflare": "astro build",
    "build:node": "astro build",
    "build:vercel": "astro build",
    "build:netlify": "astro build",
    "start:node": "node ./dist/server/entry.mjs",
    "preview": "astro build && wrangler dev -c dist/server/wrangler.json",
    "deploy": "astro build && wrangler deploy -c dist/server/wrangler.json",
    "cf-typegen": "wrangler types",
    "astro": "astro",
    "release:patch": "npm version patch -m \"chore: release %s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"chore: release %s\" && git push && git push --tags",
    "release:major": "npm version major -m \"chore: release %s\" && git push && git push --tags"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/netlify": "^7.0.0",
    "@astrojs/node": "^10.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "bare-fs": "4.7.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.61.1",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
